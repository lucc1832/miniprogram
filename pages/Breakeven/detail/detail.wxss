page {
  background: #f5f8fb;
  color: #101827;
}

.wrap {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 30rpx 28rpx 72rpx;
  background: linear-gradient(180deg, #f8fbff 0%, #edf8f5 60%, #f7fafc 100%);
}

.card,
.loading-card {
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .96);
  border: 1rpx solid #e9eef4;
  box-shadow: 0 16rpx 38rpx rgba(15, 23, 42, .07);
  box-sizing: border-box;
}

.loading-card {
  padding: 80rpx 20rpx;
  text-align: center;
  color: #7a8797;
  font-size: 28rpx;
  font-weight: 800;
}

.hero {
  padding: 34rpx 26rpx;
  text-align: center;
  color: #fff;
  border: 0;
  background: linear-gradient(135deg, #111827 0%, #4354b4 62%, #20b5a8 100%);
  box-shadow: 0 22rpx 44rpx rgba(53, 75, 171, .2);
}

.hero.warn {
  background: linear-gradient(135deg, #22160b 0%, #b76a00 62%, #f2b84a 100%);
}

.hero.danger {
  background: linear-gradient(135deg, #220d12 0%, #b83245 62%, #ee8473 100%);
}

.type-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 46rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, .16);
  color: rgba(255, 255, 255, .92);
  font-size: 23rpx;
  font-weight: 900;
}

.name {
  margin-top: 20rpx;
  color: #fff;
  font-size: 42rpx;
  line-height: 1.25;
  font-weight: 900;
  word-break: break-word;
}

.meta-row {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.meta-row text {
  max-width: 260rpx;
  height: 44rpx;
  line-height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, .14);
  color: rgba(255, 255, 255, .9);
  font-size: 23rpx;
  font-weight: 800;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  box-sizing: border-box;
}

.hero-value {
  margin-top: 26rpx;
  color: #fff;
  font-size: 58rpx;
  line-height: 1.05;
  font-weight: 900;
  word-break: break-word;
}

.hero-sub {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, .82);
  font-size: 25rpx;
  font-weight: 800;
}

.info-card,
.progress-card {
  margin-top: 20rpx;
  padding: 26rpx 22rpx;
}

.section-title {
  color: #111827;
  font-size: 30rpx;
  line-height: 1.25;
  font-weight: 900;
  text-align: center;
}

.section-desc {
  margin-top: 8rpx;
  color: #728094;
  font-size: 23rpx;
  line-height: 1.4;
}

.info-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 22rpx;
}

.info-cell {
  flex: 1 0 calc(50% - 8rpx);
  min-width: 0;
  min-height: 126rpx;
  padding: 22rpx 12rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  text-align: center;
  box-sizing: border-box;
}

.info-label,
.money-label {
  color: #758397;
  font-size: 23rpx;
  line-height: 1.35;
  font-weight: 800;
}

.info-value,
.money-value {
  margin-top: 12rpx;
  color: #111827;
  font-size: 30rpx;
  line-height: 1.2;
  font-weight: 900;
  word-break: break-word;
}

.section-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.pct {
  flex: none;
  min-width: 110rpx;
  text-align: center;
  color: #12a474;
  font-size: 42rpx;
  line-height: 1.05;
  font-weight: 900;
}

.bar {
  height: 14rpx;
  margin-top: 24rpx;
  border-radius: 999rpx;
  background: #e8eef4;
  overflow: hidden;
}

.bar-inner {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #12a474, #5ed1b2);
}

.money-row {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
}

.money-row > view {
  flex: 1;
  min-width: 0;
  padding: 20rpx 12rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  text-align: center;
}

.actions {
  display: flex;
  justify-content: center;
  gap: 18rpx;
  margin-top: 26rpx;
}

.btn-pill {
  flex: 1;
  max-width: 300rpx;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 16rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 900;
  box-shadow: 0 14rpx 26rpx rgba(15, 23, 42, .08);
}

.btn-edit {
  color: #fff;
  background: #111827;
}

.btn-archive {
  color: #516176;
  background: #eef3f7;
}
