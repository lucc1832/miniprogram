<view class="wrap">
  <view wx:if="{{!good}}" class="loading-card">加载中...</view>

  <block wx:else>
    <view class="hero card {{good.expireTone}}">
      <view class="type-pill">{{good.detailTypeLabel}}</view>
      <view class="name">{{good.name}}</view>
      <view class="meta-row">
        <text>{{good.categoryName || '未分类'}}</text>
        <text>{{good.statusLabel}}</text>
      </view>

      <block wx:if="{{good.isExpire}}">
        <view class="hero-value">{{good.expireDaysText}}</view>
        <view class="hero-sub">{{good.expireStage}}</view>
      </block>

      <block wx:else>
        <view class="hero-value">¥{{dailyCostStr}}</view>
        <view class="hero-sub">当前日均成本</view>
      </block>
    </view>

    <view class="card info-card">
      <view class="section-title">基础信息</view>
      <view class="info-grid">
        <view class="info-cell">
          <view class="info-label">购买日期</view>
          <view class="info-value">{{good.buyDate || '-'}}</view>
        </view>
        <view class="info-cell" wx:if="{{good.isExpire}}">
          <view class="info-label">到期日期</view>
          <view class="info-value">{{good.expireDate || '长期有效'}}</view>
        </view>
        <view class="info-cell" wx:if="{{!good.isExpire}}">
          <view class="info-label">购买价格</view>
          <view class="info-value">¥{{good.buyPrice}}</view>
        </view>
        <view class="info-cell" wx:if="{{!good.isExpire}}">
          <view class="info-label">使用天数</view>
          <view class="info-value">{{usedDays}} 天</view>
        </view>
      </view>
    </view>

    <view wx:if="{{!good.isExpire}}" class="card progress-card">
      <view class="section-row">
        <view>
          <view class="section-title">回本进度</view>
          <view class="section-desc">预计回本日：{{good.breakevenAt || '-'}}</view>
        </view>
        <view class="pct">{{roiPct}}%</view>
      </view>
      <view class="bar">
        <view class="bar-inner" style="width: {{roiPct}}%"></view>
      </view>
      <view class="money-row">
        <view>
          <view class="money-label">已摊销</view>
          <view class="money-value">¥{{totalValueStr}}</view>
        </view>
        <view>
          <view class="money-label">剩余差额</view>
          <view class="money-value">¥{{roiGap}}</view>
        </view>
      </view>
    </view>

    <view class="actions">
      <view class="btn-pill btn-edit" bindtap="goEdit">编辑物品</view>
      <view class="btn-pill btn-archive" bindtap="toggleArchive">{{good.status==='archived' ? '恢复使用' : '归档物品'}}</view>
    </view>
  </block>
</view>
