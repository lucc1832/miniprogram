<view class="wrap">
  <view class="page-hero card">
    <view class="hero-title">数据备份</view>
    <view class="hero-sub">导出到剪贴板，也可以从 JSON 恢复记录</view>
  </view>

  <view class="card panel">
    <view class="title">导出数据</view>
    <view class="muted">生成当前分类、物品和使用记录的 JSON。</view>
    <button class="btn" bindtap="exportJson">生成并复制</button>
    <view wx:if="{{exportText}}" class="box">
      <textarea value="{{exportText}}" auto-height="true"></textarea>
    </view>
  </view>

  <view class="card panel">
    <view class="title">导入数据</view>
    <view class="muted">粘贴之前导出的 JSON，导入会新增记录。</view>
    <view class="box">
      <textarea placeholder="粘贴 JSON" placeholder-class="placeholder" value="{{importText}}" bindinput="setImport" auto-height="true"></textarea>
    </view>
    <button class="btn danger" bindtap="importJson">导入数据</button>
  </view>
</view>
