page {
  background: #f5f8fb;
  color: #101827;
}

.wrap {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 30rpx 28rpx 72rpx;
  background: linear-gradient(180deg, #f8fbff 0%, #edf8f5 62%, #f7fafc 100%);
}

.card {
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .96);
  border: 1rpx solid #e9eef4;
  box-shadow: 0 16rpx 38rpx rgba(15, 23, 42, .07);
  box-sizing: border-box;
}

.page-hero {
  padding: 32rpx 26rpx;
  color: #fff;
  border: 0;
  background: linear-gradient(135deg, #111827 0%, #4354b4 62%, #20b5a8 100%);
  text-align: center;
}

.hero-title {
  font-size: 38rpx;
  line-height: 1.2;
  font-weight: 900;
}

.hero-sub {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, .82);
  font-size: 24rpx;
  line-height: 1.45;
}

.panel {
  margin-top: 18rpx;
  padding: 28rpx 24rpx;
  text-align: center;
}

.title {
  color: #111827;
  font-size: 32rpx;
  line-height: 1.25;
  font-weight: 900;
}

.muted {
  margin-top: 10rpx;
  color: #728094;
  font-size: 24rpx;
  line-height: 1.45;
}

.btn {
  width: 340rpx;
  height: 78rpx;
  line-height: 78rpx;
  margin: 24rpx auto 0;
  border-radius: 16rpx;
  background: #111827;
  color: #fff;
  font-size: 27rpx;
  font-weight: 900;
  box-shadow: 0 14rpx 26rpx rgba(17, 24, 39, .16);
}

.btn::after {
  border: 0;
}

.btn.danger {
  background: #d84d4d;
  box-shadow: 0 14rpx 26rpx rgba(216, 77, 77, .15);
}

.box {
  margin-top: 22rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  border: 1rpx solid #edf1f5;
  box-sizing: border-box;
}

textarea {
  width: 100%;
  min-height: 220rpx;
  color: #263244;
  font-size: 24rpx;
  line-height: 1.55;
  text-align: left;
  box-sizing: border-box;
}

.placeholder {
  color: #9aa4b2;
}
