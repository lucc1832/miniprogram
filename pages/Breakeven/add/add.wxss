page {
  background: #f5f8fb;
  color: #101827;
}

.wrap {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx 28rpx 170rpx;
  background: linear-gradient(180deg, #f8fbff 0%, #edf8f5 62%, #f7fafc 100%);
}

.card {
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .96);
  border: 1rpx solid #e9eef4;
  box-shadow: 0 16rpx 38rpx rgba(15, 23, 42, .07);
  box-sizing: border-box;
}

.form {
  padding: 22rpx;
}

.field-block {
  margin-bottom: 18rpx;
  padding: 26rpx 22rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  text-align: center;
  box-sizing: border-box;
}

.field-block.compact {
  flex: 1;
  min-width: 0;
  margin-bottom: 0;
}

.label {
  color: #101827;
  font-size: 28rpx;
  line-height: 1.25;
  font-weight: 900;
  text-align: center;
}

.choice-group {
  display: flex;
  gap: 14rpx;
  margin-top: 22rpx;
  padding: 8rpx;
  border-radius: 18rpx;
  background: #eef3f7;
}

.choice {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 15rpx;
  text-align: center;
  color: #6b788b;
  font-size: 28rpx;
  font-weight: 900;
}

.choice-active {
  color: #fff;
  background: #111827;
  box-shadow: 0 14rpx 26rpx rgba(17, 24, 39, .18);
}

.ocr-panel {
  margin-bottom: 18rpx;
  padding: 30rpx 24rpx;
  border-radius: 16rpx;
  text-align: center;
  background: linear-gradient(135deg, #effbf5 0%, #f5f8ff 100%);
  border: 1rpx solid #e3f1eb;
  box-sizing: border-box;
}

.ocr-title {
  color: #101827;
  font-size: 30rpx;
  line-height: 1.25;
  font-weight: 900;
}

.ocr-desc {
  margin-top: 10rpx;
  color: #7a8797;
  font-size: 24rpx;
  line-height: 1.4;
}

.ocr-btn {
  width: 340rpx;
  height: 76rpx;
  line-height: 76rpx;
  margin: 24rpx auto 0;
  border-radius: 18rpx;
  background: #12a474;
  color: #fff;
  font-size: 27rpx;
  font-weight: 900;
  box-shadow: 0 14rpx 26rpx rgba(18, 164, 116, .18);
}

.ocr-btn::after {
  border: 0;
}

.ocr-summary {
  margin-top: 18rpx;
  color: #119b70;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.45;
  text-align: center;
}

.input,
.picker,
.main-picker {
  width: 100%;
  min-height: 66rpx;
  line-height: 66rpx;
  margin-top: 18rpx;
  text-align: center;
  color: #263244;
  font-size: 31rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.input {
  height: 70rpx;
}

.price-input {
  color: #12a474;
  font-size: 40rpx;
  font-weight: 900;
}

.placeholder {
  color: #9aa4b2;
  font-weight: 600;
}

.field-grid {
  display: flex;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.cat-add {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 144rpx;
  height: 48rpx;
  margin: 16rpx auto 0;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #e9fbf3;
  color: #10a875;
  font-size: 23rpx;
  font-weight: 900;
}

.cat-creator {
  margin-bottom: 18rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background: #fff;
  border: 1rpx solid #e9eef4;
  box-shadow: 0 12rpx 26rpx rgba(15, 23, 42, .05);
}

.cat-input {
  height: 72rpx;
  text-align: center;
  border-radius: 14rpx;
  background: #f8fafc;
  color: #111827;
  font-size: 27rpx;
}

.cat-actions {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-top: 18rpx;
}

.cat-action {
  min-width: 150rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  border-radius: 16rpx;
  font-size: 25rpx;
  font-weight: 900;
}

.cat-action.ghost {
  color: #647386;
  background: #f1f5f9;
}

.cat-action.primary {
  color: #fff;
  background: #111827;
}

.status-group {
  max-width: 520rpx;
  margin-left: auto;
  margin-right: auto;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 28rpx calc(22rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, .96);
  box-shadow: 0 -12rpx 34rpx rgba(15, 23, 42, .08);
  display: flex;
  justify-content: center;
  gap: 18rpx;
  box-sizing: border-box;
  z-index: 20;
}

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  line-height: 1;
  padding: 0;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 900;
  text-align: center;
  box-sizing: border-box;
}

.btn::after {
  border: 0;
}

.btn-save {
  width: 340rpx;
  max-width: calc(100vw - 56rpx);
  color: #fff;
  background: #111827;
  box-shadow: 0 18rpx 34rpx rgba(17, 24, 39, .18);
}

.btn-del {
  width: 220rpx;
  color: #d84d4d;
  background: #fff0f0;
}
