<view class="wrap">
  <view class="card form">
    <view class="field-block">
      <view class="label">记录类型</view>
      <view class="choice-group">
        <view class="choice {{type==='expire'?'choice-active':''}}" bindtap="selectType" data-value="expire">到期便签</view>
        <view class="choice {{type==='roi'?'choice-active':''}}" bindtap="selectType" data-value="roi">使用成本</view>
      </view>
    </view>

    <view class="ocr-panel">
      <view class="ocr-title">截图识别</view>
      <view class="ocr-desc">识别商品名、购买日期和价格</view>
      <button class="ocr-btn" loading="{{recognizing}}" bindtap="chooseReceiptImage">{{recognizing ? '识别中' : '选择截图'}}</button>
      <view wx:if="{{ocrSummary}}" class="ocr-summary">{{ocrSummary}}</view>
    </view>

    <view class="field-block">
      <view class="label">物品名称</view>
      <input class="input" placeholder="请输入物品名称" placeholder-class="placeholder" value="{{form.name}}" bindinput="setName" />
    </view>

    <view class="field-grid">
      <view class="field-block compact">
        <view class="label">分类</view>
        <picker mode="selector" range="{{catNames}}" value="{{catIndex}}" bindchange="onCatPick">
          <view class="picker">{{catNames[catIndex] || '未分类'}}</view>
        </picker>
        <view class="cat-add" bindtap="openCategoryCreator">新增分类</view>
      </view>

      <view class="field-block compact">
        <view class="label">购买日期</view>
        <picker mode="date" value="{{form.buyDate}}" bindchange="pickBuyDate">
          <view class="picker">{{form.buyDate}}</view>
        </picker>
      </view>
    </view>

    <view wx:if="{{showCategoryCreator}}" class="cat-creator">
      <input class="cat-input" placeholder="输入新分类" placeholder-class="placeholder" value="{{newCategoryName}}" bindinput="setNewCategoryName" />
      <view class="cat-actions">
        <view class="cat-action ghost" bindtap="closeCategoryCreator">取消</view>
        <view class="cat-action primary" bindtap="createCategory">{{creatingCategory ? '新增中' : '新增'}}</view>
      </view>
    </view>

    <block wx:if="{{type==='expire'}}">
      <view class="field-block">
        <view class="label">到期日期</view>
        <picker mode="date" value="{{form.expireDate}}" bindchange="pickExpire">
          <view class="picker main-picker">{{form.expireDate || '请选择到期日期'}}</view>
        </picker>
      </view>
    </block>

    <block wx:if="{{type==='expire' && priceEnabled}}">
      <view class="field-block">
        <view class="label">购买价格</view>
        <input class="input price-input" type="digit" placeholder="可选，识别后自动填入" placeholder-class="placeholder" value="{{form.buyPrice}}" bindinput="setPrice" />
      </view>
    </block>

    <block wx:if="{{type==='roi'}}">
      <view class="field-block">
        <view class="label">购买价格</view>
        <input class="input price-input" type="digit" placeholder="请输入金额" placeholder-class="placeholder" value="{{form.buyPrice}}" bindinput="setPrice" />
      </view>

      <view class="field-block">
        <view class="label">使用状态</view>
        <view class="choice-group status-group">
          <view class="choice {{form.status==='using'?'choice-active':''}}" bindtap="selectStatus" data-value="using">使用中</view>
          <view class="choice {{form.status==='archived'?'choice-active':''}}" bindtap="selectStatus" data-value="archived">归档</view>
        </view>
      </view>
    </block>
  </view>

  <view class="bottom-bar">
    <button wx:if="{{isEdit}}" class="btn btn-del" bindtap="remove">删除</button>
    <button class="btn btn-save" bindtap="save">保存</button>
  </view>
</view>
