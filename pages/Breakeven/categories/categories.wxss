page {
  background: #f5f8fb;
  color: #101827;
}

.wrap {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 30rpx 28rpx 72rpx;
  background: linear-gradient(180deg, #f8fbff 0%, #edf8f5 62%, #f7fafc 100%);
}

.card {
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .96);
  border: 1rpx solid #e9eef4;
  box-shadow: 0 16rpx 38rpx rgba(15, 23, 42, .07);
  box-sizing: border-box;
}

.page-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 30rpx 26rpx;
  color: #fff;
  border: 0;
  background: linear-gradient(135deg, #111827 0%, #4354b4 62%, #20b5a8 100%);
}

.hero-title {
  font-size: 38rpx;
  line-height: 1.2;
  font-weight: 900;
}

.hero-sub {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, .82);
  font-size: 24rpx;
  line-height: 1.45;
}

.hero-count {
  flex: none;
  min-width: 112rpx;
  height: 74rpx;
  line-height: 74rpx;
  text-align: center;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, .16);
  color: #fff;
  font-size: 25rpx;
  font-weight: 900;
}

.toolbar {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-top: 18rpx;
  padding: 18rpx;
}

.btn {
  flex: 1;
  max-width: 260rpx;
  height: 74rpx;
  line-height: 74rpx;
  border-radius: 16rpx;
  background: #111827;
  color: #fff;
  font-size: 27rpx;
  font-weight: 900;
  text-align: center;
}

.btn::after {
  border: 0;
}

.btn.ghost {
  color: #536277;
  background: #eef3f7;
}

.list {
  margin-top: 18rpx;
  padding: 18rpx;
}

.row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-height: 92rpx;
  padding: 18rpx;
  margin-bottom: 14rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  box-sizing: border-box;
}

.rank {
  flex: none;
  width: 54rpx;
  height: 54rpx;
  line-height: 54rpx;
  border-radius: 50%;
  text-align: center;
  background: #e9fbf3;
  color: #10a875;
  font-size: 23rpx;
  font-weight: 900;
}

.name {
  flex: 1;
  min-width: 0;
  text-align: center;
  color: #111827;
  font-size: 29rpx;
  line-height: 1.3;
  font-weight: 900;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.ops {
  flex: none;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.move {
  display: flex;
  gap: 8rpx;
}

.move text,
.del {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 72rpx;
  height: 46rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.move text {
  color: #536277;
  background: #eef3f7;
}

.del {
  color: #d84d4d;
  background: #fff0f0;
}

.empty {
  padding: 68rpx 20rpx;
  text-align: center;
}

.empty-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
}

.empty-desc {
  margin-top: 14rpx;
  color: #748295;
  font-size: 25rpx;
  line-height: 1.55;
}

.mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 28rpx;
  background: rgba(15, 23, 42, .42);
  box-sizing: border-box;
  z-index: 30;
}

.modal {
  width: 100%;
  max-width: 680rpx;
  padding: 30rpx 26rpx calc(30rpx + env(safe-area-inset-bottom));
  border-radius: 24rpx;
  background: #fff;
  box-sizing: border-box;
}

.modal-title {
  text-align: center;
  color: #111827;
  font-size: 32rpx;
  font-weight: 900;
}

.minput {
  height: 82rpx;
  margin-top: 26rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  color: #111827;
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
}

.placeholder {
  color: #9aa4b2;
  font-weight: 600;
}

.mbtns {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-top: 24rpx;
}
