<view class="wrap">
  <view class="page-hero card">
    <view>
      <view class="hero-title">分类管理</view>
      <view class="hero-sub">把物品分组，筛选和统计会更清楚</view>
    </view>
    <view class="hero-count">{{categories.length}} 类</view>
  </view>

  <view class="toolbar card">
    <button class="btn ghost" bindtap="toggleSort">{{sorting? '完成排序' : '调整排序'}}</button>
    <button class="btn" bindtap="openAdd">新增分类</button>
  </view>

  <view class="card list">
    <view wx:if="{{categories.length===0}}" class="empty">
      <view class="empty-title">暂无分类</view>
      <view class="empty-desc">可以先创建食品、证件、电子设备等常用分类</view>
    </view>

    <block wx:for="{{categories}}" wx:key="_id">
      <view class="row">
        <view class="rank">{{index + 1}}</view>
        <view class="name">{{item.name}}</view>
        <view class="ops">
          <view wx:if="{{sorting}}" class="move">
            <text bindtap="moveUp" data-idx="{{index}}">上移</text>
            <text bindtap="moveDown" data-idx="{{index}}">下移</text>
          </view>
          <text class="del" bindtap="delCat" data-id="{{item._id}}">删除</text>
        </view>
      </view>
    </block>
  </view>

  <view wx:if="{{showAdd}}" class="mask" bindtap="closeAdd">
    <view class="modal" catchtap="noop">
      <view class="modal-title">新增分类</view>
      <input class="minput" placeholder="输入分类名称" placeholder-class="placeholder" value="{{newName}}" bindinput="setNewName"/>
      <view class="mbtns">
        <button class="btn ghost" bindtap="closeAdd">取消</button>
        <button class="btn" bindtap="addCat">保存</button>
      </view>
    </view>
  </view>
</view>
