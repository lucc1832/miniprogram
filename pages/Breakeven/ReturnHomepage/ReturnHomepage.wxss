page {
  background: #f5f8fb;
  color: #101827;
}

.container {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 30rpx 28rpx 150rpx;
  background: linear-gradient(180deg, #f8fbff 0%, #edf8f5 58%, #f7fafc 100%);
}

.card {
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .94);
  border: 1rpx solid rgba(224, 231, 238, .92);
  box-shadow: 0 16rpx 38rpx rgba(15, 23, 42, .07);
  box-sizing: border-box;
}

.page-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.head-main {
  min-width: 0;
}

.head-kicker {
  display: inline-flex;
  align-items: center;
  height: 36rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(16, 185, 129, .1);
  color: #0f9f74;
  font-size: 22rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.title {
  font-size: 46rpx;
  line-height: 1.1;
  font-weight: 900;
  color: #101827;
}

.subtitle {
  margin-top: 10rpx;
  color: #657386;
  font-size: 25rpx;
  line-height: 1.45;
}

.head-date {
  flex: none;
  padding: 12rpx 18rpx;
  border-radius: 14rpx;
  background: #fff;
  color: #4b5a6b;
  font-size: 24rpx;
  font-weight: 700;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, .06);
}

.seg {
  display: flex;
  padding: 8rpx;
  border-radius: 20rpx;
  background: #fff;
  border: 1rpx solid #e8eef4;
  margin-bottom: 18rpx;
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, .06);
}

.seg-item {
  flex: 1;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  color: #667487;
  font-size: 28rpx;
  font-weight: 800;
}

.seg-item.active {
  color: #fff;
  background: #111827;
  box-shadow: 0 14rpx 24rpx rgba(17, 24, 39, .16);
}

.seg-item.active-green {
  color: #fff;
  background: #12a474;
  box-shadow: 0 14rpx 24rpx rgba(18, 164, 116, .2);
}

.search {
  height: 78rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 0 18rpx 0 24rpx;
  margin-bottom: 18rpx;
}

.search-input {
  flex: 1;
  height: 78rpx;
  color: #111827;
  font-size: 27rpx;
  text-align: center;
}

.search-action {
  flex: none;
  min-width: 84rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  border-radius: 999rpx;
  background: #edf3f7;
  color: #4b5a6b;
  font-size: 23rpx;
  font-weight: 800;
}

.filter-toolbar {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  padding: 16rpx;
  margin-bottom: 18rpx;
}

.filter-picker {
  min-width: 0;
}

.filter-value {
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 10rpx;
  border-radius: 14rpx;
  color: #526174;
  background: #f3f6f9;
  font-size: 22rpx;
  font-weight: 800;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.filter-manage {
  grid-column: 1 / -1;
  height: 42rpx;
  line-height: 42rpx;
  text-align: center;
}

.summary {
  color: #fff;
  min-height: 172rpx;
  padding: 28rpx;
  margin-bottom: 18rpx;
  overflow: hidden;
  border: 0;
}

.summary-purple {
  background: linear-gradient(135deg, #121a2b 0%, #4659bf 60%, #25b8ab 100%);
  box-shadow: 0 20rpx 42rpx rgba(53, 75, 171, .22);
}

.summary-green {
  background: linear-gradient(135deg, #0d2b28 0%, #0fa678 62%, #73d4bf 100%);
  box-shadow: 0 20rpx 42rpx rgba(15, 166, 120, .2);
}

.sum-left,
.sum-right,
.sum-3col {
  width: 100%;
}

.summary > block,
.summary block {
  width: 100%;
}

.sum-label {
  color: rgba(255, 255, 255, .78);
  font-size: 24rpx;
  font-weight: 700;
}

.sum-value {
  max-width: 100%;
  margin-top: 8rpx;
  color: #fff;
  font-size: 48rpx;
  line-height: 1.08;
  font-weight: 900;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.sum-mini,
.sum-mini-right,
.sum-bottom {
  color: rgba(255, 255, 255, .84);
  font-size: 24rpx;
  line-height: 1.45;
}

.sum-mini {
  margin-top: 12rpx;
}

.sum-strong {
  color: #fff;
  font-weight: 900;
}

.sum-right {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.date-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 132rpx;
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: rgba(255, 255, 255, .92);
  background: rgba(255, 255, 255, .15);
  font-size: 23rpx;
  font-weight: 800;
}

.sum-3col {
  display: flex;
  align-items: stretch;
  gap: 16rpx;
}

.sum-col {
  min-width: 0;
}

.sum-col.left {
  flex: 1.25;
}

.sum-col.mid {
  flex: .95;
  padding: 18rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .13);
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.sum-col.right {
  flex: none;
  display: flex;
  align-items: flex-start;
}

.sum-value-sm {
  margin-top: 8rpx;
  font-size: 29rpx;
  line-height: 1.2;
  color: #fff;
  font-weight: 900;
  word-break: break-all;
}

.sum-bottom {
  margin-top: 18rpx;
}

.insight {
  padding: 26rpx;
  margin-bottom: 18rpx;
}

.insight-purple {
  background: linear-gradient(180deg, #ffffff 0%, #f5f7ff 100%);
}

.insight-green {
  background: linear-gradient(180deg, #ffffff 0%, #f1fbf6 100%);
}

.insight-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.insight-copy {
  min-width: 0;
  flex: 1;
}

.section-label {
  color: #7b8796;
  font-size: 24rpx;
  font-weight: 800;
}

.insight-title {
  margin-top: 8rpx;
  color: #111827;
  font-size: 34rpx;
  line-height: 1.32;
  font-weight: 900;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.insight-meta,
.guide-text {
  color: #657386;
  font-size: 25rpx;
  line-height: 1.55;
}

.insight-meta {
  margin-top: 8rpx;
}

.guide-text {
  margin-top: 20rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: rgba(241, 245, 249, .85);
}

.focus-meter {
  flex: none;
  width: 146rpx;
  min-height: 132rpx;
  border-radius: 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  background: #eef7f2;
  color: #119b70;
}

.focus-meter.warn {
  background: #fff7e7;
  color: #ba6b00;
}

.focus-meter.danger {
  background: #fff0f0;
  color: #d04444;
}

.focus-value {
  max-width: 126rpx;
  font-size: 36rpx;
  line-height: 1.1;
  font-weight: 900;
  word-break: break-all;
}

.focus-unit {
  margin-top: 8rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.stat-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.mini-stat {
  flex: 1 0 calc(50% - 8rpx);
  min-width: 0;
  padding: 20rpx 18rpx;
  text-align: center;
}

.mini-stat-active {
  border-color: rgba(18, 164, 116, .4);
  background: #f0fbf6;
}

.mini-label {
  color: #718093;
  font-size: 23rpx;
  font-weight: 800;
}

.mini-value {
  margin-top: 8rpx;
  color: #111827;
  font-size: 36rpx;
  line-height: 1.1;
  font-weight: 900;
}

.mini-value text {
  margin-left: 4rpx;
  font-size: 22rpx;
  color: #718093;
  font-weight: 800;
}

.cat-wrap {
  padding: 24rpx;
  margin-bottom: 18rpx;
}

.cat-purple {
  background: #fbfbff;
}

.cat-green {
  background: #f8fffb;
}

.cat-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #111827;
  font-size: 28rpx;
  font-weight: 900;
}

.manage {
  color: #11a272;
  font-size: 24rpx;
  font-weight: 800;
}

.cat-scroll {
  width: 100%;
  margin-top: 20rpx;
  white-space: nowrap;
}

.cat-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 132rpx;
  height: 112rpx;
  margin-right: 16rpx;
  border-radius: 18rpx;
  background: #f3f6f9;
  color: #5c6a7d;
  box-sizing: border-box;
}

.cat-active {
  color: #fff;
  background: #111827;
  box-shadow: 0 14rpx 24rpx rgba(17, 24, 39, .16);
}

.cat-num {
  font-size: 34rpx;
  line-height: 1.05;
  font-weight: 900;
}

.cat-name {
  max-width: 116rpx;
  margin-top: 8rpx;
  font-size: 22rpx;
  font-weight: 800;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.pill-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 22rpx;
}

.pill {
  flex: 1 0 146rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  border-radius: 16rpx;
  color: #637386;
  background: #f1f5f9;
  font-size: 25rpx;
  font-weight: 900;
}

.pill-active {
  color: #fff;
  background: #111827;
}

.list {
  padding: 24rpx;
}

.list-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 20rpx;
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
}

.sort {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #5d6b7f;
  font-size: 23rpx;
  font-weight: 800;
}

.empty {
  padding: 58rpx 24rpx;
  text-align: center;
}

.empty-illustration {
  width: 92rpx;
  height: 92rpx;
  line-height: 88rpx;
  margin: 0 auto 20rpx;
  border-radius: 50%;
  color: #12a474;
  background: #eaf8f2;
  font-size: 48rpx;
  font-weight: 500;
  text-align: center;
}

.empty-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
}

.empty-desc {
  margin: 14rpx auto 0;
  max-width: 520rpx;
  color: #748295;
  font-size: 25rpx;
  line-height: 1.55;
}

.empty-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-top: 26rpx;
  min-width: 180rpx;
  height: 66rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: #111827;
  color: #fff;
  font-size: 25rpx;
  font-weight: 900;
}

.cost-card {
  margin-bottom: 18rpx;
  border-radius: 16rpx;
  background: #fff;
  border: 1rpx solid #edf1f5;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, .05);
  box-sizing: border-box;
}

.expire-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 178rpx;
  padding: 22rpx;
}

.expire-card.soon {
  border-color: rgba(245, 158, 11, .38);
}

.expire-card.expired {
  border-color: rgba(220, 68, 68, .38);
}

.cost-left {
  flex: 1;
  min-width: 0;
  text-align: center;
}

.cost-name {
  color: #111827;
  font-size: 31rpx;
  line-height: 1.28;
  font-weight: 900;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.expire-row {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 13rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 86rpx;
  max-width: 180rpx;
  height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #eef8f3;
  color: #11a272;
  font-size: 22rpx;
  font-weight: 900;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  box-sizing: border-box;
}

.tag-status {
  background: #fff5e7;
  color: #bd7200;
}

.expire-date,
.roi-date {
  color: #708092;
  font-size: 23rpx;
  line-height: 1.4;
}

.days-box {
  flex: none;
  width: 154rpx;
  min-height: 126rpx;
  border-radius: 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  color: #0f9f74;
  background: #edf9f3;
}

.days-box.soon {
  color: #b76a00;
  background: #fff5e5;
}

.days-box.expired {
  color: #cf3c3c;
  background: #fff0f0;
}

.days-box.none {
  color: #4f5d70;
  background: #f2f5f8;
}

.days-num {
  max-width: 134rpx;
  font-size: 44rpx;
  line-height: 1;
  font-weight: 900;
  word-break: break-all;
}

.days-infinite {
  font-size: 42rpx;
}

.days-text {
  margin-top: 10rpx;
  font-size: 21rpx;
  font-weight: 900;
}

.roi-card {
  padding: 22rpx;
}

.roi-card-head {
  text-align: center;
}

.roi-tags {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.roi-metrics {
  display: flex;
  gap: 14rpx;
  margin-top: 20rpx;
}

.roi-metric {
  flex: 1;
  min-width: 0;
  padding: 18rpx 8rpx;
  border-radius: 16rpx;
  background: #f6f8fb;
  text-align: center;
}

.metric-value {
  color: #111827;
  font-size: 28rpx;
  line-height: 1.12;
  font-weight: 900;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.roi-metric.price .metric-value {
  color: #10a875;
}

.metric-label {
  margin-top: 8rpx;
  color: #748295;
  font-size: 21rpx;
  font-weight: 800;
}

.roi-progress {
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #eef2f6;
}

.roi-progress-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #5f6e82;
  font-size: 24rpx;
  font-weight: 900;
}

.bar {
  height: 12rpx;
  margin-top: 14rpx;
  border-radius: 999rpx;
  background: #e8eef4;
  overflow: hidden;
}

.bar-inner {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #12a474, #5ed1b2);
}

.roi-date {
  margin-top: 14rpx;
  text-align: center;
}

.fab {
  position: fixed;
  right: 34rpx;
  bottom: calc(40rpx + env(safe-area-inset-bottom));
  width: 108rpx;
  height: 108rpx;
  line-height: 104rpx;
  text-align: center;
  border-radius: 50%;
  background: #12a474;
  color: #fff;
  font-size: 58rpx;
  font-weight: 700;
  box-shadow: 0 20rpx 40rpx rgba(18, 164, 116, .26);
  z-index: 20;
}
