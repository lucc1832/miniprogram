page {
  background: #f5f8fb;
}

.me-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx 28rpx calc(48rpx + env(safe-area-inset-bottom));
  color: #101828;
  background:
    radial-gradient(circle at 16% 6%, rgba(20, 184, 135, 0.14) 0, rgba(20, 184, 135, 0) 240rpx),
    radial-gradient(circle at 90% 18%, rgba(88, 120, 255, 0.14) 0, rgba(88, 120, 255, 0) 260rpx),
    linear-gradient(180deg, #f7fafc 0%, #eef7f3 46%, #f8fafc 100%);
}

.hero {
  position: relative;
  overflow: hidden;
  padding: 34rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, #0f172a 0%, #16335d 54%, #10a985 100%);
  box-shadow: 0 28rpx 60rpx rgba(15, 23, 42, 0.18);
}

.hero-glow {
  position: absolute;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
}

.hero-glow-a {
  width: 260rpx;
  height: 260rpx;
  right: -72rpx;
  top: -88rpx;
}

.hero-glow-b {
  width: 180rpx;
  height: 180rpx;
  left: -70rpx;
  bottom: -76rpx;
}

.profile-row {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
}

.avatar-wrapper {
  position: relative;
  flex: 0 0 128rpx;
  width: 128rpx;
  height: 128rpx;
  border-radius: 40rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.2);
  box-shadow: 0 16rpx 34rpx rgba(0, 0, 0, 0.2);
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 40rpx;
}

.avatar-edit {
  position: absolute;
  right: 8rpx;
  bottom: 8rpx;
  width: 42rpx;
  height: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 22rpx;
  line-height: 1;
  background: rgba(15, 23, 42, 0.72);
  color: #fff;
}

.profile-main {
  flex: 1;
  min-width: 0;
  margin-left: 24rpx;
}

.nickname-input {
  width: 100%;
  height: 54rpx;
  min-height: 54rpx;
  color: #fff;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 54rpx;
}

.nickname-input::placeholder {
  color: rgba(255, 255, 255, 0.7);
}

.chip-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.profile-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 42rpx;
  padding: 0 18rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1;
  color: rgba(255, 255, 255, 0.9);
  background: rgba(255, 255, 255, 0.15);
}

.profile-chip.gold {
  color: #3d2a00;
  background: linear-gradient(135deg, #ffe08a, #ffbd41);
}

.profile-chip.bound {
  color: #e8fff5;
  background: rgba(20, 184, 135, 0.28);
}

.login-state {
  align-self: flex-start;
  flex: 0 0 auto;
  min-width: 84rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 12rpx;
  border-radius: 999rpx;
  color: rgba(255, 255, 255, 0.7);
  font-size: 20rpx;
  line-height: 1;
  background: rgba(255, 255, 255, 0.12);
}

.login-state.active {
  color: #dcfff0;
  background: rgba(20, 184, 135, 0.28);
}

.account-strip {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 34rpx;
  padding: 24rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.strip-left {
  display: flex;
  align-items: center;
  min-width: 0;
}

.strip-icon {
  flex: 0 0 auto;
  width: 58rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 18rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.16);
  font-size: 28rpx;
  line-height: 1;
}

.strip-title {
  color: #fff;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.2;
}

.strip-desc {
  max-width: 430rpx;
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 22rpx;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.strip-action {
  flex: 0 0 auto;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 22rpx;
  border-radius: 999rpx;
  color: #0f172a;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 1;
  background: #fff;
}

.stats-card {
  display: flex;
  align-items: stretch;
  margin-top: 28rpx;
  padding: 18rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 18rpx 44rpx rgba(15, 23, 42, 0.08);
}

.stat-item {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 116rpx;
  border-radius: 24rpx;
}

.stat-item + .stat-item {
  border-left: 1rpx solid #edf1f5;
}

.stat-num {
  color: #0f172a;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1;
}

.stat-label {
  margin-top: 12rpx;
  color: #7b8794;
  font-size: 22rpx;
  line-height: 1;
}

.sync-panel {
  margin-top: 26rpx;
  padding: 28rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 18rpx 44rpx rgba(15, 23, 42, 0.08);
}

.sync-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.panel-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.2;
}

.panel-subtitle {
  margin-top: 8rpx;
  color: #8a95a3;
  font-size: 22rpx;
  line-height: 1.2;
}

.sync-pill {
  height: 46rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: #9aa4b2;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
  background: #eef2f6;
}

.sync-pill.ready {
  color: #08765a;
  background: #ddf8ed;
}

.status-grid {
  display: flex;
  gap: 14rpx;
  margin-top: 24rpx;
}

.status-box {
  flex: 1;
  min-width: 0;
  padding: 20rpx 10rpx;
  border-radius: 22rpx;
  background: #f6f9fb;
  text-align: center;
}

.status-value {
  color: #111827;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-label {
  margin-top: 10rpx;
  color: #98a2b3;
  font-size: 21rpx;
  font-weight: 700;
  line-height: 1;
}

.data-panel {
  margin-top: 26rpx;
  padding: 24rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 18rpx 44rpx rgba(15, 23, 42, 0.08);
}

.data-head {
  padding: 0 2rpx 18rpx;
}

.data-action-grid {
  display: flex;
  flex-wrap: wrap;
  margin: -8rpx;
}

.data-action-card {
  width: calc(50% - 16rpx);
  min-height: 150rpx;
  margin: 8rpx;
  padding: 22rpx 18rpx;
  border-radius: 24rpx;
  background: #f6f9fb;
  box-sizing: border-box;
}

.data-action-card.primary {
  color: #fff;
  background: #132238;
}

.data-action-card.primary .data-action-title,
.data-action-card.primary .data-action-desc {
  color: #fff;
}

.data-action-card.primary .data-action-desc {
  opacity: .72;
}

.data-action-card.secondary {
  min-height: 118rpx;
}

.data-action-card:active {
  transform: scale(0.98);
}

.data-action-icon {
  width: 54rpx;
  height: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 14rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  line-height: 1;
  background: #ffffff;
  box-shadow: 0 8rpx 18rpx rgba(15, 23, 42, 0.06);
}

.data-action-title {
  color: #111827;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 1.2;
}

.data-action-desc {
  margin-top: 8rpx;
  color: #8a95a3;
  font-size: 22rpx;
  line-height: 1.35;
}

.data-action-card.danger {
  background: #fff5f5;
}

.data-action-card.danger .data-action-title {
  color: #d92d20;
}

.menu-list {
  margin-top: 28rpx;
}

.menu-group {
  margin-bottom: 28rpx;
}

.group-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 0 6rpx 14rpx;
}

.group-title {
  color: #111827;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.1;
}

.group-subtitle {
  max-width: 390rpx;
  color: #98a2b3;
  font-size: 21rpx;
  line-height: 1.2;
  text-align: right;
}

.group-content {
  overflow: hidden;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 16rpx 38rpx rgba(15, 23, 42, 0.06);
}

.menu-item {
  min-height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 26rpx;
  border-bottom: 1rpx solid #f0f3f7;
  box-sizing: border-box;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #f7fafc;
}

.danger-item .item-icon {
  background: #fff1f1;
}

.item-left {
  display: flex;
  align-items: center;
  min-width: 0;
}

.item-icon {
  flex: 0 0 auto;
  width: 62rpx;
  height: 62rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 18rpx;
  border-radius: 20rpx;
  font-size: 30rpx;
  line-height: 1;
  background: #f3f7fb;
}

.item-text {
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.item-name {
  color: #1d2939;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.2;
}

.item-desc {
  max-width: 420rpx;
  margin-top: 8rpx;
  color: #98a2b3;
  font-size: 22rpx;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-danger {
  color: #d92d20;
}

.item-right {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 18rpx;
}

.arrow,
.picker-val {
  color: #b7c0cc;
  font-size: 28rpx;
  line-height: 1;
}

.picker-val {
  min-width: 116rpx;
  text-align: right;
  color: #667085;
  font-size: 24rpx;
}

.row-switch {
  transform: scale(0.78);
  transform-origin: right center;
}

.footer-info {
  padding: 12rpx 0 6rpx;
  color: #b4beca;
  font-size: 21rpx;
  line-height: 1;
  text-align: center;
}

.modal-layer {
  position: fixed;
  z-index: 999;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.modal-layer.centered {
  align-items: center;
}

.modal-layer.centered .modal-card {
  width: calc(100% - 72rpx);
  padding: 34rpx;
  border-radius: 28rpx;
  box-shadow: 0 24rpx 70rpx rgba(15, 23, 42, .3);
}

.modal-layer.centered .modal-handle {
  display: none;
}

.modal-mask {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.48);
}

.modal-card {
  position: relative;
  z-index: 1;
  width: 100%;
  max-height: 82vh;
  margin: 0 24rpx;
  padding: 18rpx 34rpx calc(34rpx + env(safe-area-inset-bottom));
  border-radius: 34rpx 34rpx 0 0;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 20% 0%, rgba(20, 184, 135, 0.12) 0, rgba(20, 184, 135, 0) 230rpx),
    #ffffff;
  box-shadow: 0 -20rpx 60rpx rgba(15, 23, 42, 0.2);
}

.modal-card.danger {
  background:
    radial-gradient(circle at 20% 0%, rgba(217, 45, 32, 0.1) 0, rgba(217, 45, 32, 0) 230rpx),
    #ffffff;
}

.modal-handle {
  width: 78rpx;
  height: 8rpx;
  margin: 0 auto 28rpx;
  border-radius: 999rpx;
  background: #d9e0e8;
}

.modal-icon {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 18rpx;
  border-radius: 24rpx;
  font-size: 36rpx;
  line-height: 1;
  background: #f2f7fb;
}

.modal-title {
  color: #101828;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.25;
  text-align: center;
}

.modal-desc {
  max-height: 170rpx;
  margin: 18rpx auto 0;
  color: #667085;
  font-size: 25rpx;
  line-height: 1.55;
  text-align: center;
  overflow: auto;
}

.account-form {
  margin-top: 26rpx;
}

.account-tabs {
  display: flex;
  padding: 8rpx;
  margin-bottom: 20rpx;
  border-radius: 24rpx;
  background: #f1f5f9;
}

.account-tab {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  color: #667085;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 1;
}

.account-tab.active {
  color: #fff;
  background: linear-gradient(135deg, #111827, #21304f);
  box-shadow: 0 12rpx 24rpx rgba(17, 24, 39, 0.16);
}

.account-input {
  height: 92rpx;
  min-height: 92rpx;
  padding: 0 28rpx;
  margin-top: 16rpx;
  border-radius: 24rpx;
  color: #101828;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 92rpx;
  text-align: center;
  background: #f6f8fb;
}

.form-note {
  margin-top: 18rpx;
  color: #98a2b3;
  font-size: 22rpx;
  line-height: 1.45;
  text-align: center;
}

.form-error {
  margin-top: 14rpx;
  color: #d92d20;
  font-size: 23rpx;
  line-height: 1.3;
  text-align: center;
}

.bound-card {
  margin-top: 28rpx;
  padding: 26rpx;
  border-radius: 26rpx;
  background: #f6f8fb;
  text-align: center;
}

.bound-label {
  color: #98a2b3;
  font-size: 22rpx;
  line-height: 1;
}

.bound-value {
  margin-top: 14rpx;
  color: #101828;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1;
}

.bound-note {
  margin-top: 16rpx;
  color: #667085;
  font-size: 23rpx;
  line-height: 1.45;
}

.modal-actions {
  display: flex;
  align-items: center;
  margin-top: 34rpx;
}

.modal-btn {
  flex: 1;
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 1;
  text-align: center;
}

.modal-btn + .modal-btn {
  margin-left: 18rpx;
}

.modal-btn.secondary {
  color: #475467;
  background: #f1f4f8;
}

.modal-btn.primary {
  color: #fff;
  background: linear-gradient(135deg, #111827, #21304f);
  box-shadow: 0 16rpx 34rpx rgba(17, 24, 39, 0.2);
}

.modal-btn.primary.danger {
  background: linear-gradient(135deg, #d92d20, #b42318);
  box-shadow: 0 16rpx 34rpx rgba(217, 45, 32, 0.18);
}

.modal-btn.disabled {
  opacity: 0.68;
}
