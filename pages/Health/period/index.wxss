page {
  background: #f5f8fb;
  color: #101827;
}

.wrap {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx 24rpx calc(46rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #fbf7fb 0%, #eff8f5 58%, #f7fafc 100%);
}

.card {
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .96);
  border: 1rpx solid #edf0f5;
  box-shadow: 0 16rpx 38rpx rgba(28, 39, 66, .07);
  box-sizing: border-box;
}

.hero {
  padding: 32rpx 28rpx 28rpx;
  border-radius: 18rpx;
  color: #fff;
  background: linear-gradient(135deg, #111827 0%, #a43f6a 55%, #24b89d 100%);
  box-shadow: 0 22rpx 46rpx rgba(164, 63, 106, .18);
}

.hero-top,
.section-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.eyebrow {
  color: rgba(255, 255, 255, .76);
  font-size: 23rpx;
  font-weight: 800;
}

.title {
  margin-top: 8rpx;
  font-size: 48rpx;
  line-height: 1.1;
  font-weight: 900;
}

.privacy-btn {
  flex: none;
  min-width: 126rpx;
  height: 50rpx;
  line-height: 50rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  text-align: center;
  color: rgba(255, 255, 255, .92);
  background: rgba(255, 255, 255, .15);
  font-size: 22rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.status-title {
  margin-top: 34rpx;
  font-size: 43rpx;
  line-height: 1.22;
  font-weight: 900;
}

.cycle-ring {
  width: 210rpx;
  height: 210rpx;
  margin: 30rpx auto 0;
  padding: 16rpx;
  border-radius: 50%;
  background: conic-gradient(#ffffff 0 68%, rgba(255, 255, 255, .2) 68% 100%);
  box-sizing: border-box;
}

.cycle-ring-inner {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(17, 24, 39, .36);
}

.cycle-ring-value {
  color: #fff;
  font-size: 58rpx;
  line-height: 1;
  font-weight: 900;
}

.cycle-ring-label {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, .74);
  font-size: 21rpx;
  font-weight: 800;
}

.status-meta {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, .78);
  font-size: 25rpx;
  line-height: 1.5;
}

.hero-grid {
  display: flex;
  gap: 14rpx;
  margin-top: 28rpx;
}

.hero-cell {
  flex: 1;
  min-width: 0;
  padding: 18rpx 8rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .14);
  text-align: center;
}

.cell-value {
  color: #fff;
  font-size: 29rpx;
  line-height: 1.15;
  font-weight: 900;
  word-break: break-word;
}

.cell-label {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, .72);
  font-size: 21rpx;
  font-weight: 800;
}

.quick-card {
  display: flex;
  gap: 16rpx;
  padding: 18rpx;
  margin-top: 18rpx;
}

.quick-btn {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 16rpx;
  text-align: center;
  font-size: 27rpx;
  font-weight: 900;
}

.quick-btn.start {
  color: #fff;
  background: #111827;
}

.quick-btn.end {
  color: #b33f70;
  background: #fff0f6;
}

.quick-btn.disabled {
  opacity: .38;
  box-shadow: none;
}

.forecast-card,
.form-card,
.entry-card,
.settings-card,
.history-card {
  margin-top: 18rpx;
  padding: 26rpx 22rpx;
}

.entry-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.entry-btn {
  flex: none;
  min-width: 170rpx;
  height: 68rpx;
  line-height: 68rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  color: #fff;
  background: #111827;
  text-align: center;
  font-size: 25rpx;
  font-weight: 900;
  box-shadow: 0 12rpx 24rpx rgba(17, 24, 39, .14);
  box-sizing: border-box;
}

.section-title {
  color: #111827;
  font-size: 30rpx;
  line-height: 1.25;
  font-weight: 900;
}

.section-sub {
  margin-top: 8rpx;
  color: #748195;
  font-size: 23rpx;
  line-height: 1.45;
}

.forecast-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 22rpx;
}

.forecast-item {
  flex: 1 0 calc(50% - 7rpx);
  min-width: 0;
  padding: 20rpx 12rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  text-align: center;
  box-sizing: border-box;
}

.forecast-item.wide {
  flex-basis: 100%;
}

.forecast-label,
.field-label {
  color: #718093;
  font-size: 23rpx;
  line-height: 1.35;
  font-weight: 800;
  text-align: center;
}

.forecast-value {
  margin-top: 10rpx;
  color: #111827;
  font-size: 30rpx;
  line-height: 1.2;
  font-weight: 900;
  word-break: break-word;
}

.date-row,
.settings-row {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
}

.date-box,
.setting-box {
  flex: 1;
  min-width: 0;
  padding: 22rpx 14rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  text-align: center;
  box-sizing: border-box;
}

.picker-value,
.setting-input {
  width: 100%;
  min-height: 58rpx;
  line-height: 58rpx;
  margin-top: 14rpx;
  color: #111827;
  font-size: 29rpx;
  font-weight: 900;
  text-align: center;
  box-sizing: border-box;
}

.end-date {
  color: #5d6879;
  font-size: 25rpx;
}

.switch-row {
  height: 58rpx;
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.muted {
  color: #8d98a8;
}

.field-block {
  margin-top: 18rpx;
  padding: 22rpx 16rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  box-sizing: border-box;
}

.field-label text {
  color: #d94f82;
  font-weight: 900;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12rpx;
  margin-top: 18rpx;
}

.chip {
  min-width: 124rpx;
  height: 58rpx;
  line-height: 58rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  text-align: center;
  background: #eef3f7;
  color: #607086;
  font-size: 24rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.chip.active {
  color: #fff;
  background: #d94f82;
  box-shadow: 0 12rpx 22rpx rgba(217, 79, 130, .16);
}

.chip.mood.active {
  background: #111827;
}

.note {
  width: 100%;
  min-height: 128rpx;
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: #fff;
  color: #263244;
  font-size: 25rpx;
  line-height: 1.55;
  text-align: center;
  box-sizing: border-box;
}

.placeholder {
  color: #9aa4b2;
}

.form-actions {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-top: 22rpx;
}

.save-btn,
.cancel-btn,
.settings-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 82rpx;
  line-height: 1;
  padding: 0;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 900;
  text-align: center;
  box-sizing: border-box;
}

.save-btn {
  width: 340rpx;
  color: #fff;
  background: #111827;
  box-shadow: 0 16rpx 30rpx rgba(17, 24, 39, .16);
}

.cancel-btn {
  width: 190rpx;
  color: #68778b;
  background: #eef3f7;
}

.settings-btn {
  width: 300rpx;
  margin: 22rpx auto 0;
  color: #fff;
  background: #d94f82;
}

button::after {
  border: 0;
}

.history-card {
  padding-bottom: 12rpx;
}

.empty {
  padding: 52rpx 16rpx;
  text-align: center;
}

.empty-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
}

.empty-desc {
  margin-top: 12rpx;
  color: #748195;
  font-size: 24rpx;
  line-height: 1.5;
}

.record-item {
  display: flex;
  gap: 16rpx;
  padding: 22rpx 0;
  border-top: 1rpx solid #eef2f6;
}

.record-main {
  flex: 1;
  min-width: 0;
  text-align: center;
}

.record-range {
  color: #111827;
  font-size: 29rpx;
  line-height: 1.25;
  font-weight: 900;
}

.record-meta,
.record-tags,
.record-note {
  margin-top: 8rpx;
  color: #6e7d91;
  font-size: 23rpx;
  line-height: 1.45;
  word-break: break-word;
}

.record-note {
  color: #9a5772;
}

.record-actions {
  flex: none;
  width: 86rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.record-actions view {
  width: 74rpx;
  height: 42rpx;
  line-height: 42rpx;
  border-radius: 999rpx;
  text-align: center;
  background: #eef3f7;
  color: #5d6879;
  font-size: 21rpx;
  font-weight: 900;
}

.record-actions .danger {
  color: #d84d4d;
  background: #fff0f0;
}

.watermark {
  margin-top: 22rpx;
  color: #9aa4b2;
  font-size: 22rpx;
  line-height: 1.45;
  text-align: center;
}

.form-sheet {
  position: fixed;
  z-index: 999;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.sheet-mask {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(17, 24, 39, .46);
}

.sheet-panel {
  position: relative;
  z-index: 1;
  width: 100%;
  max-height: 88vh;
  padding: 16rpx 24rpx calc(26rpx + env(safe-area-inset-bottom));
  border-radius: 28rpx 28rpx 0 0;
  background: #ffffff;
  box-shadow: 0 -18rpx 48rpx rgba(17, 24, 39, .18);
  box-sizing: border-box;
}

.sheet-handle {
  width: 78rpx;
  height: 8rpx;
  margin: 0 auto 24rpx;
  border-radius: 999rpx;
  background: #d9e1ea;
}

.sheet-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  padding: 0 4rpx 18rpx;
}

.sheet-close {
  flex: none;
  min-width: 88rpx;
  height: 50rpx;
  line-height: 50rpx;
  border-radius: 999rpx;
  color: #6d7686;
  background: #f1f4f7;
  font-size: 22rpx;
  font-weight: 900;
  text-align: center;
}

.sheet-scroll {
  max-height: 62vh;
  box-sizing: border-box;
}

.sheet-actions {
  padding-top: 18rpx;
  margin-top: 0;
  background: #fff;
}
