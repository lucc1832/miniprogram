.wrap {
  min-height: 100vh;
  padding: 32rpx 32rpx calc(48rpx + env(safe-area-inset-bottom));
  background: #f7f8fa;
  box-sizing: border-box;
}

.top-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 2rpx 24rpx;
}

.eyebrow {
  color: #7a7a7a;
  font-size: 24rpx;
  line-height: 1.25;
}

.page-title {
  margin-top: 8rpx;
  color: #1a1a1a;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.2;
}

.status-pill {
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 18rpx;
  border-radius: 16rpx;
  color: #409eff;
  background: #ecf5ff;
  font-size: 22rpx;
  font-weight: 700;
}

.summary-banner {
  padding: 18rpx 22rpx;
  border-radius: 16rpx;
  color: #7a7a7a;
  background: #ffffff;
  border: 1rpx solid #edf0f4;
  font-size: 25rpx;
  line-height: 1.4;
}

.summary-strong {
  color: #27ba9b;
  font-size: 30rpx;
  font-weight: 800;
}

.recent-card {
  display: flex;
  align-items: center;
  min-height: 148rpx;
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #409eff, #27ba9b);
  box-shadow: 0 16rpx 34rpx rgba(64, 158, 255, 0.18);
  box-sizing: border-box;
}

.recent-card:active {
  opacity: 0.86;
}

.empty-recent {
  color: #1a1a1a;
  background: #ffffff;
  border: 1rpx dashed #d8dde5;
  box-shadow: none;
}

.recent-icon {
  flex: 0 0 auto;
  width: 76rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.2);
  font-size: 38rpx;
  line-height: 1;
}

.empty-recent .recent-icon {
  color: #409eff;
  background: #ecf5ff;
}

.recent-copy {
  flex: 1;
  min-width: 0;
  margin-left: 20rpx;
}

.recent-label {
  font-size: 21rpx;
  opacity: 0.76;
}

.recent-title {
  margin-top: 4rpx;
  font-size: 31rpx;
  font-weight: 800;
  line-height: 1.25;
}

.recent-desc {
  margin-top: 6rpx;
  font-size: 22rpx;
  opacity: 0.8;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.continue-btn {
  flex: 0 0 auto;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 18rpx;
  padding: 0 20rpx;
  border-radius: 16rpx;
  color: #16775f;
  background: #ffffff;
  font-size: 23rpx;
  font-weight: 800;
}

.section-head {
  margin: 34rpx 2rpx 18rpx;
}

.section-title {
  color: #1a1a1a;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.25;
}

.section-sub {
  margin-top: 6rpx;
  color: #7a7a7a;
  font-size: 23rpx;
}

.grid {
  display: flex;
  flex-wrap: wrap;
  margin: -10rpx;
}

.tool-card {
  width: calc(50% - 20rpx);
  min-height: 226rpx;
  margin: 10rpx;
  padding: 22rpx;
  border: 1rpx solid #edf0f4;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(26, 26, 26, 0.05);
  box-sizing: border-box;
}

.tool-card:active {
  transform: scale(0.985);
  opacity: 0.86;
}

.card-top,
.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-top {
  margin-bottom: 18rpx;
}

.card-ico {
  width: 62rpx;
  height: 62rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  font-size: 34rpx;
  line-height: 1;
  background: #f3f5f7;
}

.card-badge {
  max-width: 116rpx;
  padding: 5rpx 10rpx;
  border-radius: 8rpx;
  color: #7a7a7a;
  background: #f3f5f7;
  font-size: 20rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-title {
  color: #1a1a1a;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 1.25;
}

.card-desc {
  height: 68rpx;
  margin-top: 10rpx;
  color: #7a7a7a;
  font-size: 23rpx;
  line-height: 1.45;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.card-footer {
  margin-top: 14rpx;
  color: #7a7a7a;
  font-size: 22rpx;
}

.arrow {
  color: #c0c4cc;
  font-size: 30rpx;
}

.accent-purple .card-ico,
.accent-purple .card-badge { background: #f2efff; color: #7856d8; }
.accent-blue .card-ico,
.accent-blue .card-badge { background: #ecf5ff; color: #409eff; }
.accent-rose .card-ico,
.accent-rose .card-badge { background: #fff0f4; color: #db6486; }
.accent-amber .card-ico,
.accent-amber .card-badge { background: #fff5e6; color: #ff9500; }
.accent-green .card-ico,
.accent-green .card-badge { background: #eaf9f5; color: #27ba9b; }
.accent-period .card-ico,
.accent-period .card-badge { background: #f7eff8; color: #a56aad; }
.accent-slate .card-ico,
.accent-slate .card-badge { background: #f1f3f5; color: #8a939f; }

.tool-card.disabled {
  opacity: 0.58;
}
