.wrap {
  min-height: 100vh;
  padding: 28rpx 24rpx calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: #f5f7fb;
}

.hero {
  position: relative;
  overflow: hidden;
  padding: 34rpx 30rpx 30rpx;
  border-radius: 28rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #28324f 0%, #4f7cff 58%, #42c6a5 100%);
  box-shadow: 0 20rpx 48rpx rgba(55, 91, 180, 0.18);
}

.hero::after {
  content: "";
  position: absolute;
  right: -70rpx;
  top: -70rpx;
  width: 220rpx;
  height: 220rpx;
  border: 28rpx solid rgba(255, 255, 255, 0.14);
  border-radius: 50%;
}

.hero-top {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.eyebrow {
  font-size: 24rpx;
  opacity: 0.86;
}

.status-pill {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  font-size: 22rpx;
}

.hero-title {
  position: relative;
  z-index: 1;
  font-size: 50rpx;
  line-height: 1.14;
  font-weight: 800;
}

.hero-sub {
  position: relative;
  z-index: 1;
  max-width: 560rpx;
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.55;
  color: rgba(255, 255, 255, 0.82);
}

.quick-row {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  margin-top: 30rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.14);
  backdrop-filter: blur(8px);
}

.quick-item {
  flex: 1;
  min-width: 0;
}

.quick-num {
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1;
}

.quick-label {
  margin-top: 8rpx;
  font-size: 23rpx;
  color: rgba(255, 255, 255, 0.78);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.quick-divider {
  width: 1rpx;
  height: 52rpx;
  margin: 0 24rpx;
  background: rgba(255, 255, 255, 0.25);
}

.recent-entry:active {
  opacity: 0.72;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin: 34rpx 4rpx 18rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #1f2937;
}

.section-sub {
  margin-top: 6rpx;
  font-size: 23rpx;
  color: #8b95a5;
}

.grid {
  display: flex;
  flex-wrap: wrap;
  margin: -9rpx;
}

.tool-card {
  position: relative;
  width: calc(50% - 18rpx);
  min-height: 226rpx;
  margin: 9rpx;
  padding: 22rpx 20rpx 18rpx;
  box-sizing: border-box;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 30rpx rgba(28, 39, 66, 0.06);
  border: 1rpx solid rgba(31, 41, 55, 0.05);
}

.tool-card::before {
  content: "";
  position: absolute;
  left: 20rpx;
  top: 20rpx;
  width: 54rpx;
  height: 54rpx;
  border-radius: 18rpx;
  opacity: 0.13;
}

.tool-card:active {
  transform: scale(0.985);
  opacity: 0.86;
}

.card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.card-ico {
  position: relative;
  z-index: 1;
  font-size: 42rpx;
  line-height: 54rpx;
}

.card-badge {
  max-width: 110rpx;
  padding: 5rpx 12rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: #647085;
  font-size: 20rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-title {
  font-size: 29rpx;
  line-height: 1.28;
  font-weight: 800;
  color: #1f2937;
}

.card-desc {
  min-height: 66rpx;
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.45;
  color: #7a8494;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
  font-size: 23rpx;
  color: #667085;
}

.arrow {
  font-size: 36rpx;
  line-height: 1;
  color: #c2c8d2;
}

.accent-purple::before { background: #6b5cff; }
.accent-purple .card-badge { background: #f0efff; color: #6b5cff; }
.accent-blue::before { background: #2f80ed; }
.accent-blue .card-badge { background: #eaf3ff; color: #2f80ed; }
.accent-rose::before { background: #ff6b81; }
.accent-rose .card-badge { background: #fff0f3; color: #ff6b81; }
.accent-amber::before { background: #ff9800; }
.accent-amber .card-badge { background: #fff4df; color: #c76f00; }
.accent-green::before { background: #26a269; }
.accent-green .card-badge { background: #eaf8f1; color: #1c8b58; }
.accent-period::before { background: #d94f82; }
.accent-period .card-badge { background: #fff0f6; color: #c33f70; }
.accent-slate::before { background: #64748b; }
.accent-slate .card-badge { background: #eef2f7; color: #64748b; }

.tool-card.disabled {
  opacity: 0.62;
}
