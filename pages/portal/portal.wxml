<view class="wrap responsive-container">
  <view class="top-row">
    <view>
      <view class="eyebrow">{{todayLabel}}</view>
      <view class="page-title">小小工具箱</view>
    </view>
    <view class="status-pill">常用工具</view>
  </view>

  <view class="summary-banner">
    <text>当前已启用 </text>
    <text class="summary-strong">{{enabledCount}}</text>
    <text> 个生活模块</text>
  </view>

  <view class="recent-card" wx:if="{{recentModule}}" bindtap="openRecent">
    <view class="recent-icon">{{recentModule.icon}}</view>
    <view class="recent-copy">
      <view class="recent-label">最近使用</view>
      <view class="recent-title">{{recentModule.title}}</view>
      <view class="recent-desc">{{recentModule.desc}}</view>
    </view>
    <view class="continue-btn">继续使用</view>
  </view>

  <view class="recent-card empty-recent" wx:else>
    <view class="recent-icon">＋</view>
    <view class="recent-copy">
      <view class="recent-label">最近使用</view>
      <view class="recent-title">选择一个生活模块</view>
      <view class="recent-desc">打开后会在这里提供快捷入口</view>
    </view>
  </view>

  <view class="section-head">
    <view>
      <view class="section-title">全部模块</view>
      <view class="section-sub">点击卡片进入对应功能</view>
    </view>
  </view>

  <view class="grid">
    <view
      class="tool-card {{item.accentClass}} {{item.disabled ? 'disabled' : ''}}"
      wx:for="{{modules}}"
      wx:key="key"
      bindtap="handleCardTap"
      data-index="{{index}}"
    >
      <view class="card-top">
        <view class="card-ico">{{item.icon}}</view>
        <view class="card-badge" wx:if="{{item.badge}}">{{item.badge}}</view>
      </view>
      <view class="card-title">{{item.title}}</view>
      <view class="card-desc">{{item.disabled ? item.desc : (item.summary || item.desc)}}</view>
      <view class="card-footer">
        <text>{{item.disabled ? '即将上线' : '进入'}}</text>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>
</view>
