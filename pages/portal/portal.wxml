<view class="wrap responsive-container">
  <view class="hero">
    <view class="hero-top">
      <view class="eyebrow">{{todayLabel}}</view>
      <view class="status-pill">常用工具</view>
    </view>
    <view class="hero-title">小小工具箱</view>
    <view class="hero-sub">把天气、纪念日、厨房和记录都收在一个顺手的入口里。</view>

    <view class="quick-row">
      <view class="quick-item">
        <view class="quick-num">{{enabledCount}}</view>
        <view class="quick-label">已启用</view>
      </view>
      <view class="quick-divider"></view>
      <view class="quick-item recent-entry" wx:if="{{recentModule}}" bindtap="openRecent">
        <view class="quick-num">{{recentModule.icon}}</view>
        <view class="quick-label">继续 {{recentModule.title}}</view>
      </view>
      <view class="quick-item" wx:else>
        <view class="quick-num">＋</view>
        <view class="quick-label">选择模块</view>
      </view>
    </view>
  </view>

  <view class="section-head">
    <view>
      <view class="section-title">全部模块</view>
      <view class="section-sub">点击卡片进入对应功能</view>
    </view>
  </view>

  <view class="grid">
    <view
      class="tool-card {{item.accentClass}} {{item.disabled ? 'disabled' : ''}}"
      wx:for="{{modules}}"
      wx:key="key"
      bindtap="handleCardTap"
      data-index="{{index}}"
    >
      <view class="card-top">
        <view class="card-ico">{{item.icon}}</view>
        <view class="card-badge" wx:if="{{item.badge}}">{{item.badge}}</view>
      </view>
      <view class="card-title">{{item.title}}</view>
      <view class="card-desc">{{item.desc}}</view>
      <view class="card-footer">
        <text>{{item.disabled ? '即将上线' : '进入'}}</text>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>
</view>
