<view class="container">
  <view class="custom-nav" style="height: {{navBarHeight}}px; padding-top: {{statusBarHeight}}px;">
    <view class="nav-content" style="height: {{navBarHeight}}px;">
      <view class="search-container" style="height: {{menuButtonHeight}}px; margin-top: {{menuButtonTop - statusBarHeight}}px; width: {{menuButtonLeft - 12}}px;">
        <view class="search-box">
          <icon type="search" size="14" color="#7c8aa0" class="search-icon"/>
          <input
            class="search-input"
            placeholder="输入城市名称"
            placeholder-class="placeholder-style"
            bindinput="onInput"
            value="{{searchText}}"
            focus
            confirm-type="search"
          />
          <view class="clear-btn" bindtap="clearSearch" wx:if="{{searchText.length > 0}}">
            <icon type="clear" size="14" color="#a8b2c2"/>
          </view>
        </view>
        <view class="cancel-btn" bindtap="onCancel">取消</view>
      </view>
    </view>
  </view>

  <scroll-view scroll-y class="main-content" style="padding-top: {{statusBarHeight + navBarHeight}}px;">
    <view class="hero">
      <view class="hero-title">添加城市</view>
      <view class="hero-sub">按城市名搜索，或从常用城市里快速添加。</view>
    </view>

    <view class="search-results-list" wx:if="{{searchText.length > 0}}">
      <view class="section-header compact">
        <text class="section-title">搜索结果</text>
        <text class="section-count">{{searchResults.length}} 个</text>
      </view>

      <block wx:for="{{searchResults}}" wx:key="adcode">
        <view class="result-card fade-in" bindtap="onSelectCity" data-name="{{item.name}}" data-lat="{{item.lat}}" data-lon="{{item.lon}}" data-adcode="{{item.adcode}}">
          <view class="result-icon">⌖</view>
          <view class="card-left">
            <text class="city-name">{{item.name}}</text>
            <view class="city-meta">
              <text class="province-tag" wx:if="{{item.province}}">{{item.province}}</text>
              <text class="country-tag">{{item.district || item.country}}</text>
            </view>
          </view>
          <view class="add-btn">
            <text>＋</text>
          </view>
        </view>
      </block>

      <view wx:if="{{searchResults.length === 0}}" class="empty-state">
        <view class="empty-title">没有找到这个城市</view>
        <view class="empty-sub">换一个城市名试试，比如“杭州”或“广州”。</view>
      </view>
    </view>

    <view class="default-view" wx:else>
      <view class="section">
        <view class="section-header">
          <text class="section-title">当前定位</text>
        </view>
        <view class="location-card" bindtap="onSelectCity" data-name="{{currentLocation}}">
          <view class="loc-mark">⌖</view>
          <view class="loc-main">
            <text class="loc-text">{{currentLocation}}</text>
            <text class="loc-sub">使用当前位置作为天气城市</text>
          </view>
          <view class="loc-arrow">›</view>
        </view>
      </view>

      <view class="section">
        <view class="section-header">
          <text class="section-title">热门城市</text>
        </view>
        <view class="grid-layout">
          <block wx:for="{{hotCities}}" wx:key="*this">
            <view class="grid-chip" bindtap="onSelectCity" data-name="{{item}}">
              <text>{{item}}</text>
            </view>
          </block>
        </view>
      </view>

      <view class="section">
        <view class="section-header">
          <text class="section-title">更多城市</text>
        </view>
        <view class="grid-layout">
          <block wx:for="{{intlCities}}" wx:key="*this">
            <view class="grid-chip muted" bindtap="onSelectCity" data-name="{{item}}">
              <text>{{item}}</text>
            </view>
          </block>
        </view>
      </view>
    </view>

    <view class="footer-safe-area"></view>
  </scroll-view>
</view>
