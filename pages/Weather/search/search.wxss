page {
  background: #eef5ff;
}

.container {
  min-height: 100vh;
  color: #162033;
  background: linear-gradient(180deg, #eaf4ff 0%, #f7f9fc 42%, #f7f9fc 100%);
}

.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  z-index: 1000;
  background: rgba(238, 245, 255, 0.92);
  backdrop-filter: blur(16px);
  box-shadow: 0 1rpx 0 rgba(42, 65, 100, 0.08);
}

.nav-content {
  width: 100%;
  position: relative;
}

.search-container {
  display: flex;
  align-items: center;
  margin-left: 24rpx;
}

.search-box {
  flex: 1;
  height: 100%;
  display: flex;
  align-items: center;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 2rpx solid rgba(35, 103, 242, 0.1);
  box-shadow: 0 8rpx 22rpx rgba(34, 74, 130, 0.08);
  box-sizing: border-box;
}

.search-icon {
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  height: 100%;
  color: #172033;
  font-size: 28rpx;
}

.placeholder-style {
  color: #9aa7ba;
}

.clear-btn {
  padding: 10rpx;
}

.cancel-btn {
  margin-left: 20rpx;
  font-size: 30rpx;
  color: #324157;
  white-space: nowrap;
}

.main-content {
  height: 100vh;
  box-sizing: border-box;
}

.hero {
  padding: 34rpx 30rpx 24rpx;
}

.hero-title {
  font-size: 46rpx;
  line-height: 1.15;
  font-weight: 850;
  color: #13213a;
}

.hero-sub {
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.5;
  color: #6f7f95;
}

.default-view,
.search-results-list {
  padding: 0 26rpx 30rpx;
  box-sizing: border-box;
}

.section {
  margin-bottom: 34rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.section-header.compact {
  padding: 0 4rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #172033;
}

.section-count {
  font-size: 24rpx;
  color: #8491a5;
}

.location-card {
  min-height: 126rpx;
  padding: 24rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #2367f2 0%, #62b5ff 100%);
  color: #ffffff;
  box-shadow: 0 18rpx 34rpx rgba(35, 103, 242, 0.22);
  box-sizing: border-box;
}

.location-card:active,
.result-card:active,
.grid-chip:active {
  transform: scale(0.985);
}

.loc-mark {
  width: 66rpx;
  height: 66rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  margin-right: 20rpx;
}

.loc-main {
  flex: 1;
  min-width: 0;
}

.loc-text {
  display: block;
  font-size: 34rpx;
  font-weight: 800;
}

.loc-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 23rpx;
  color: rgba(255, 255, 255, 0.78);
}

.loc-arrow {
  font-size: 42rpx;
  opacity: 0.82;
}

.grid-layout {
  display: flex;
  flex-wrap: wrap;
  margin: -8rpx;
}

.grid-chip {
  width: calc(25% - 16rpx);
  height: 74rpx;
  margin: 8rpx;
  border-radius: 20rpx;
  background: #ffffff;
  color: #2b384f;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 27rpx;
  font-weight: 650;
  box-shadow: 0 8rpx 20rpx rgba(32, 61, 112, 0.06);
  box-sizing: border-box;
}

.grid-chip.muted {
  color: #59677d;
  background: #fdfefe;
}

.result-card {
  display: flex;
  align-items: center;
  min-height: 122rpx;
  padding: 22rpx;
  margin-bottom: 18rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(32, 61, 112, 0.07);
  box-sizing: border-box;
}

.result-icon {
  width: 58rpx;
  height: 58rpx;
  border-radius: 20rpx;
  background: #eef5ff;
  color: #2367f2;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 18rpx;
  font-size: 30rpx;
}

.card-left {
  flex: 1;
  min-width: 0;
}

.city-name {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
  color: #172033;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.city-meta {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}

.province-tag {
  max-width: 220rpx;
  padding: 4rpx 12rpx;
  margin-right: 10rpx;
  border-radius: 999rpx;
  background: #eef5ff;
  color: #2367f2;
  font-size: 22rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.country-tag {
  color: #8a96a8;
  font-size: 22rpx;
}

.add-btn {
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  background: #2367f2;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  box-shadow: 0 8rpx 18rpx rgba(35, 103, 242, 0.22);
}

.empty-state {
  padding: 120rpx 20rpx;
  text-align: center;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #2b384f;
}

.empty-sub {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #8491a5;
}

.footer-safe-area {
  height: calc(30rpx + env(safe-area-inset-bottom));
}

.fade-in {
  opacity: 0;
  transform: translateY(10rpx);
  animation: fadeIn 0.28s ease-out forwards;
}

@keyframes fadeIn {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
