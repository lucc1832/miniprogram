<view class="weather-page {{weatherThemeClass}}">
  <view class="weather-backdrop" aria-hidden="true">
    <view class="backdrop-glow"></view>
    <view class="backdrop-cloud cloud-one"></view>
    <view class="backdrop-cloud cloud-two"></view>
    <view class="backdrop-cloud cloud-three"></view>
    <view class="backdrop-horizon"></view>
    <view class="backdrop-rain">
      <view class="rain-streak"></view>
      <view class="rain-streak"></view>
      <view class="rain-streak"></view>
      <view class="rain-streak"></view>
    </view>
  </view>

  <view class="custom-nav" style="height: {{statusBarHeight + navBarHeight}}px; padding-top: {{statusBarHeight}}px;">
    <view class="nav-content" style="height: {{navBarHeight}}px;">
      <view class="nav-icon-button" bindtap="onBack" style="height: {{menuButtonHeight}}px; margin-top: {{menuButtonTop - statusBarHeight}}px;">
        <text class="nav-back">‹</text>
      </view>
      <view class="location-trigger" bindtap="onSwitchCity" style="height: {{menuButtonHeight}}px; margin-top: {{menuButtonTop - statusBarHeight}}px;">
        <text class="city-name">{{weatherData.city || '天气预报'}}</text>
        <view class="city-switch-indicator">
          <view class="city-switch-arrow"></view>
        </view>
      </view>
      <view class="nav-actions" style="right: {{windowWidth - menuButtonLeft + 8}}px; top: {{menuButtonTop - statusBarHeight}}px; height: {{menuButtonHeight}}px;">
        <view class="nav-action nav-add" bindtap="onAddCity">＋</view>
        <view class="nav-action nav-more" bindtap="onShowMenu">
          <view class="more-dot"></view>
          <view class="more-dot"></view>
          <view class="more-dot"></view>
        </view>
      </view>
    </view>
  </view>

  <view class="loading" wx:if="{{loading}}">
    <view class="spinner"></view>
    <text>正在获取天气</text>
  </view>

  <block wx:else>
    <view wx:if="{{cacheNotice}}" class="weather-network-banner">{{cacheNotice}}</view>
    <swiper
      class="content-swiper"
      current="{{currentCityIndex}}"
      duration="260"
      disable-touch="{{cities.length <= 1}}"
      skip-hidden-item-layout="{{true}}"
      bindchange="onSwiperChange"
    >
      <block wx:for="{{cities}}" wx:key="adcode">
        <swiper-item>
          <block wx:if="{{index === currentCityIndex}}">
            <scroll-view
              scroll-y
              class="content-scroll"
              style="padding-top: {{statusBarHeight + navBarHeight}}px;"
              enable-back-to-top
              refresher-enabled="{{true}}"
              bindrefresherrefresh="onPullDownRefresh"
              refresher-triggered="{{isRefreshing}}"
            >
              <view class="weather-content">
                <view class="hero">
                  <view class="hero-status">
                    <text>{{weatherData.condition}}</text>
                    <text class="status-dot">·</text>
                    <text>{{weatherData.windDir}} {{weatherData.windSpeed}}</text>
                  </view>
                  <view class="temperature-row">
                    <text class="temperature">{{weatherData.temp}}</text>
                    <text class="degree">°</text>
                  </view>
                  <view class="hero-summary">
                    <text>{{weatherData.condition}}</text>
                    <text>{{weatherData.low}}° / {{weatherData.high}}°</text>
                    <text>{{weatherData.humidity}} 湿度</text>
                  </view>
                  <view class="hero-source">{{weatherData.source}} · {{weatherData.reportTime}}</view>
                </view>

                <view class="weather-card advice-card">
                  <view class="advice-copy">
                    <view class="section-kicker">今日建议</view>
                    <view class="advice-title">{{clothingTitle}}</view>
                    <view class="advice-text">{{clothingAdvice}}</view>
                  </view>
                  <view class="advice-icon">{{clothingIcon}}</view>
                </view>

                <view class="weather-card">
                  <view class="card-heading">
                    <view>
                      <view class="section-title">昼夜趋势</view>
                      <view class="section-subtitle">高德天气多日昼夜预报</view>
                    </view>
                    <view class="data-badge">API</view>
                  </view>
                  <scroll-view scroll-x class="period-scroll" enable-flex>
                    <view class="period-item" wx:for="{{hourlyForecast}}" wx:key="key">
                      <view class="period-time">{{item.time}}</view>
                      <view class="period-label">{{item.period}}</view>
                      <view class="period-icon">{{item.icon}}</view>
                      <view class="period-temp">{{item.temp}}°</view>
                      <view class="period-weather">{{item.text}}</view>
                    </view>
                  </scroll-view>
                </view>

                <view class="weather-card forecast-card">
                  <view class="card-heading forecast-heading">
                    <view>
                      <view class="section-title">多日天气预报</view>
                      <view class="section-subtitle">{{forecastBrief.trend}}</view>
                    </view>
                    <view class="mode-switch">
                      <view class="mode-option {{forecastMode === 'trend' ? 'active' : ''}}" bindtap="setForecastMode" data-mode="trend">趋势</view>
                      <view class="mode-option {{forecastMode === 'list' ? 'active' : ''}}" bindtap="setForecastMode" data-mode="list">列表</view>
                    </view>
                  </view>

                  <scroll-view wx:if="{{forecastMode === 'trend'}}" scroll-x class="forecast-trend-scroll" enable-flex>
                    <view class="forecast-column" wx:for="{{dailyForecast}}" wx:key="date">
                      <view class="forecast-day">{{item.shortDay}}</view>
                      <view class="forecast-date">{{item.dateLabel}}</view>
                      <view class="forecast-cond">{{item.dayWeather}}</view>
                      <view class="forecast-icon">{{item.dayIcon}}</view>
                      <view class="forecast-high">{{item.high}}°</view>
                      <view class="temp-range-track">
                        <view class="temp-range-fill" style="top: {{item.rangeTop}}%; height: {{item.rangeHeight}}%;"></view>
                        <view class="temp-range-dot high" style="top: {{item.rangeTop}}%;"></view>
                        <view class="temp-range-dot low" style="top: {{item.rangeBottom}}%;"></view>
                      </view>
                      <view class="forecast-low">{{item.low}}°</view>
                      <view class="forecast-night">{{item.nightWeather}}</view>
                    </view>
                  </scroll-view>

                  <view wx:else class="forecast-list">
                    <view class="forecast-row" wx:for="{{dailyForecast}}" wx:key="date">
                      <view class="forecast-row-day">
                        <text>{{item.day}}</text>
                        <text class="forecast-row-cond">{{item.cond}}</text>
                      </view>
                      <view class="forecast-row-icon">{{item.icon}}</view>
                      <view class="forecast-row-range">
                        <text>{{item.low}}°</text>
                        <view class="range-line">
                          <view class="range-line-fill" style="left: {{item.barLeft}}%; width: {{item.barWidth}}%;"></view>
                        </view>
                        <text>{{item.high}}°</text>
                      </view>
                    </view>
                  </view>
                </view>

                <view class="weather-card">
                  <view class="card-heading">
                    <view>
                      <view class="section-title">天气实况</view>
                      <view class="section-subtitle">实时值与本地估算已明确标注</view>
                    </view>
                  </view>
                  <view class="metric-grid">
                    <view class="metric-item" wx:for="{{detailMetrics}}" wx:key="label">
                      <view class="metric-icon">{{item.icon}}</view>
                      <view class="metric-label">{{item.label}}</view>
                      <view class="metric-value">{{item.value}}</view>
                      <view class="metric-note">{{item.note}}</view>
                    </view>
                  </view>
                </view>

                <view class="weather-card sun-card" wx:if="{{weatherData.sunrise && weatherData.sunset}}">
                  <view class="card-heading compact">
                    <view>
                      <view class="section-title">日出日落</view>
                      <view class="section-subtitle">{{weatherData.sunNote}}</view>
                    </view>
                  </view>
                  <view class="sun-labels">
                    <view>
                      <view class="sun-name">日出</view>
                      <view class="sun-time">{{weatherData.sunrise}}</view>
                    </view>
                    <view class="sun-icon">☀</view>
                    <view class="sun-right">
                      <view class="sun-name">日落</view>
                      <view class="sun-time">{{weatherData.sunset}}</view>
                    </view>
                  </view>
                  <view class="sun-track">
                    <view class="sun-track-passed" style="width: {{weatherData.sunPosition}}%;"></view>
                    <view class="sun-track-dot" style="left: {{weatherData.sunPosition}}%;"></view>
                  </view>
                </view>

                <view class="weather-card">
                  <view class="card-heading">
                    <view>
                      <view class="section-title">生活建议</view>
                      <view class="section-subtitle">根据天气实况和未来预报生成</view>
                    </view>
                  </view>
                  <view class="lifestyle-grid">
                    <view class="lifestyle-item" wx:for="{{lifestyleItems}}" wx:key="label">
                      <view class="lifestyle-icon">{{item.icon}}</view>
                      <view class="lifestyle-value">{{item.value}}</view>
                      <view class="lifestyle-label">{{item.label}}</view>
                    </view>
                  </view>
                </view>

                <view class="data-note">
                  <view class="data-note-title">数据说明</view>
                  <view class="data-note-row" wx:for="{{dataNotes}}" wx:key="text">
                    <view class="data-note-dot {{item.type}}"></view>
                    <text>{{item.text}}</text>
                  </view>
                </view>
                <view class="footer-safe-area"></view>
              </view>
            </scroll-view>
          </block>
          <view wx:else class="city-swipe-preview" style="padding-top: {{statusBarHeight + navBarHeight}}px;">
            <view class="preview-city">{{item.name}}</view>
            <view class="preview-temp">{{item.temp || '--'}}°</view>
            <view class="preview-meta">{{item.condition || '滑动切换城市'}}</view>
          </view>
        </swiper-item>
      </block>
    </swiper>
  </block>

  <view class="city-panel-mask" wx:if="{{showCityPanel}}" catchtap="closeCityPanel"></view>
  <view class="city-panel" wx:if="{{showCityPanel}}" catchtap="noop">
    <view class="panel-grabber"></view>
    <view class="panel-head">
      <view>
        <view class="panel-title">切换城市</view>
        <view class="panel-sub">{{cities.length}} 个城市 · {{weatherData.source || '高德天气'}}</view>
      </view>
      <view class="panel-add" bindtap="addCityFromPanel">＋</view>
    </view>
    <scroll-view scroll-y class="panel-city-list">
      <view class="panel-city {{index === currentCityIndex ? 'active' : ''}}" wx:for="{{cities}}" wx:key="adcode" bindtap="selectCityFromPanel" data-index="{{index}}">
        <view class="panel-city-main">
          <view class="panel-city-name-row">
            <text class="panel-city-name">{{item.name}}</text>
            <text class="panel-location-badge" wx:if="{{index === 0}}">定位</text>
            <text class="panel-current-badge" wx:if="{{index === currentCityIndex}}">当前</text>
          </view>
          <view class="panel-city-meta">{{item.province || item.district || '中国'}} · {{item.condition || '待更新'}}</view>
        </view>
        <view class="panel-weather">
          <text class="panel-temp">{{item.temp || '--'}}°</text>
          <text class="panel-check" wx:if="{{index === currentCityIndex}}">✓</text>
        </view>
      </view>
    </scroll-view>
    <view class="panel-actions">
      <view class="panel-action ghost" bindtap="openCityManager">管理城市</view>
      <view class="panel-action primary" bindtap="addCityFromPanel">添加城市</view>
    </view>
  </view>
</view>
