.weather-page {
  --page-top: #2459a8;
  --page-mid: #4d8edc;
  --page-bottom: #9fc9e8;
  --card: rgba(44, 103, 181, 0.62);
  --card-soft: rgba(60, 122, 202, 0.48);
  --line: rgba(255, 255, 255, 0.14);
  --text: #ffffff;
  --muted: rgba(255, 255, 255, 0.66);
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  color: var(--text);
  background: linear-gradient(180deg, var(--page-top) 0%, var(--page-mid) 45%, var(--page-bottom) 100%);
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.theme-sunny {
  --page-top: #1f5dac;
  --page-mid: #5aa3e8;
  --page-bottom: #b6d9ef;
  --card: rgba(51, 116, 199, 0.58);
}

.theme-rain {
  --page-top: #274865;
  --page-mid: #557d9e;
  --page-bottom: #a3bfd0;
  --card: rgba(42, 78, 112, 0.64);
}

.theme-snow {
  --page-top: #527ca3;
  --page-mid: #8ab7d4;
  --page-bottom: #dcecf5;
  --card: rgba(68, 118, 158, 0.56);
}

.theme-haze {
  --page-top: #66798b;
  --page-mid: #9caeba;
  --page-bottom: #d4dde1;
  --card: rgba(78, 100, 116, 0.58);
}

.theme-night {
  --page-top: #102d59;
  --page-mid: #274f82;
  --page-bottom: #7896b4;
  --card: rgba(20, 57, 104, 0.7);
}

.weather-backdrop {
  position: absolute;
  inset: 0;
  pointer-events: none;
  overflow: hidden;
}

.backdrop-glow {
  position: absolute;
  width: 500rpx;
  height: 500rpx;
  right: -180rpx;
  top: 180rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,255,255,.42), rgba(255,255,255,0) 68%);
  opacity: .66;
}

.backdrop-cloud {
  position: absolute;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, .22);
  box-shadow: 100rpx -40rpx 0 34rpx rgba(255,255,255,.17), 210rpx 4rpx 0 16rpx rgba(255,255,255,.13);
}

.cloud-one {
  width: 350rpx;
  height: 122rpx;
  left: -130rpx;
  top: 280rpx;
}

.cloud-two {
  width: 300rpx;
  height: 104rpx;
  right: -100rpx;
  top: 510rpx;
  opacity: .72;
}

.cloud-three {
  width: 250rpx;
  height: 88rpx;
  left: 260rpx;
  top: 730rpx;
  opacity: .28;
}

.backdrop-horizon {
  position: absolute;
  left: -10%;
  right: -10%;
  top: 760rpx;
  height: 900rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0), rgba(208,238,255,.16) 45%, rgba(255,255,255,0));
}

.backdrop-rain {
  display: none;
}

.theme-rain .backdrop-rain {
  display: block;
  position: absolute;
  inset: 0;
}

.rain-streak {
  position: absolute;
  width: 3rpx;
  height: 220rpx;
  top: 180rpx;
  left: 18%;
  border-radius: 999rpx;
  transform: rotate(18deg);
  background: linear-gradient(180deg, transparent, rgba(255,255,255,.5));
}

.rain-streak:nth-child(2) { left: 42%; top: 430rpx; opacity: .5; }
.rain-streak:nth-child(3) { left: 68%; top: 220rpx; opacity: .7; }
.rain-streak:nth-child(4) { left: 88%; top: 600rpx; opacity: .45; }

.custom-nav {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  z-index: 100;
  box-sizing: border-box;
  background: linear-gradient(180deg, rgba(12,43,91,.24), transparent);
}

.nav-content {
  position: relative;
  display: flex;
  align-items: flex-start;
  padding-left: 20rpx;
  box-sizing: border-box;
}

.nav-icon-button,
.location-trigger,
.nav-action {
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon-button {
  width: 64rpx;
  flex-shrink: 0;
}

.nav-back {
  font-size: 58rpx;
  line-height: 1;
  font-weight: 300;
}

.location-trigger {
  max-width: 330rpx;
  padding: 0 8rpx 0 4rpx;
  border-radius: 999rpx;
}

.city-name {
  max-width: 250rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 34rpx;
  font-weight: 650;
}

.city-switch-indicator {
  width: 38rpx;
  height: 38rpx;
  margin-left: 10rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255,255,255,.18);
  border-radius: 50%;
  background: rgba(255,255,255,.16);
}

.city-switch-arrow {
  width: 11rpx;
  height: 11rpx;
  margin-top: -5rpx;
  border-right: 3rpx solid rgba(255,255,255,.9);
  border-bottom: 3rpx solid rgba(255,255,255,.9);
  transform: rotate(45deg);
}

.nav-actions {
  position: absolute;
  display: flex;
  align-items: center;
  gap: 2rpx;
}

.nav-action {
  width: 56rpx;
  height: 100%;
  font-size: 34rpx;
  font-weight: 400;
  border-radius: 50%;
  color: rgba(255,255,255,.94);
}

.nav-action:active,
.location-trigger:active,
.nav-icon-button:active {
  background: rgba(255,255,255,.12);
}

.nav-add {
  font-size: 38rpx;
  line-height: 1;
}

.nav-more {
  gap: 6rpx;
}

.more-dot {
  width: 7rpx;
  height: 7rpx;
  border-radius: 50%;
  background: currentColor;
}

.content-swiper,
.content-scroll {
  width: 100%;
  height: 100vh;
}

.content-scroll {
  box-sizing: border-box;
}

.weather-content {
  padding: 0 30rpx 40rpx;
}

.loading,
.city-swipe-preview {
  position: relative;
  z-index: 2;
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.spinner {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 20rpx;
  border: 4rpx solid rgba(255,255,255,.26);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin .8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.weather-network-banner {
  position: fixed;
  left: 30rpx;
  right: 30rpx;
  top: calc(env(safe-area-inset-top) + 92rpx);
  z-index: 120;
  padding: 16rpx 22rpx;
  border-radius: 18rpx;
  background: rgba(15, 40, 74, .84);
  color: #fff;
  font-size: 22rpx;
  text-align: center;
}

.hero {
  min-height: 650rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.hero-status {
  display: flex;
  align-items: center;
  padding: 9rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,.14);
  font-size: 24rpx;
  color: rgba(255,255,255,.84);
}

.status-dot {
  margin: 0 12rpx;
  opacity: .56;
}

.temperature-row {
  display: flex;
  align-items: flex-start;
  margin-top: 22rpx;
  margin-left: 34rpx;
}

.temperature {
  font-size: 220rpx;
  line-height: .92;
  font-weight: 220;
  font-family: "DIN Alternate", "SF Pro Display", "PingFang SC", sans-serif;
  text-shadow: 0 12rpx 40rpx rgba(16,47,91,.18);
}

.degree {
  margin-top: 8rpx;
  font-size: 74rpx;
  line-height: 1;
  font-weight: 300;
}

.hero-summary {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  margin-top: 26rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.hero-source {
  margin-top: 20rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,.12);
  color: rgba(255,255,255,.66);
  font-size: 21rpx;
}

.weather-card {
  margin-bottom: 22rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(255,255,255,.13);
  border-radius: 30rpx;
  background: var(--card);
  box-shadow: 0 12rpx 34rpx rgba(20,60,112,.1);
  box-sizing: border-box;
}

.advice-card {
  min-height: 190rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, rgba(45,108,190,.8), rgba(84,145,219,.52));
}

.advice-copy {
  flex: 1;
  min-width: 0;
}

.section-kicker,
.section-subtitle {
  font-size: 22rpx;
  color: var(--muted);
}

.advice-title {
  margin-top: 9rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.advice-text {
  margin-top: 12rpx;
  font-size: 25rpx;
  line-height: 1.55;
  color: rgba(255,255,255,.72);
}

.advice-icon {
  width: 120rpx;
  margin-left: 18rpx;
  text-align: center;
  font-size: 76rpx;
  opacity: .86;
}

.card-heading {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.card-heading.compact {
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
}

.section-subtitle {
  margin-top: 6rpx;
  line-height: 1.4;
  overflow-wrap: anywhere;
}

.data-badge {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,.13);
  color: rgba(255,255,255,.7);
  font-size: 20rpx;
}

.period-scroll {
  height: 254rpx;
  white-space: nowrap;
}

.period-item {
  width: 132rpx;
  height: 236rpx;
  margin-right: 10rpx;
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 16rpx 8rpx 12rpx;
  vertical-align: top;
  border-radius: 22rpx;
  background: rgba(255,255,255,.08);
  box-sizing: border-box;
}

.period-time {
  font-size: 24rpx;
  font-weight: 650;
}

.period-label,
.period-weather {
  font-size: 19rpx;
  color: var(--muted);
}

.period-label {
  margin-top: 3rpx;
}

.period-icon {
  margin-top: 12rpx;
  font-size: 42rpx;
}

.period-temp {
  margin-top: 8rpx;
  font-size: 31rpx;
  font-weight: 700;
}

.period-weather {
  width: 112rpx;
  min-height: 42rpx;
  margin-top: 5rpx;
  overflow: visible;
  white-space: normal;
  word-break: break-all;
  line-height: 1.15;
  text-align: center;
}

.forecast-heading {
  align-items: center;
}

.mode-switch {
  flex-shrink: 0;
  display: flex;
  padding: 5rpx;
  border-radius: 999rpx;
  background: rgba(24,70,132,.22);
}

.mode-option {
  min-width: 60rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: rgba(255,255,255,.58);
  font-size: 22rpx;
  text-align: center;
}

.mode-option.active {
  background: rgba(255,255,255,.18);
  color: #fff;
}

.forecast-trend-scroll {
  height: 540rpx;
  white-space: nowrap;
}

.forecast-column {
  width: 140rpx;
  height: 520rpx;
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  vertical-align: top;
}

.forecast-day {
  font-size: 27rpx;
  font-weight: 700;
}

.forecast-date,
.forecast-cond,
.forecast-night {
  margin-top: 7rpx;
  font-size: 20rpx;
  color: var(--muted);
}

.forecast-cond,
.forecast-night {
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.forecast-icon {
  margin-top: 14rpx;
  font-size: 42rpx;
}

.forecast-high,
.forecast-low {
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.temp-range-track {
  width: 8rpx;
  height: 150rpx;
  margin-top: 12rpx;
  position: relative;
  border-radius: 999rpx;
  background: rgba(15,60,118,.2);
}

.temp-range-fill {
  position: absolute;
  left: 0;
  width: 100%;
  min-height: 12rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,.72);
}

.temp-range-dot {
  position: absolute;
  left: 50%;
  width: 14rpx;
  height: 14rpx;
  border: 3rpx solid rgba(255,255,255,.72);
  border-radius: 50%;
  background: #4b8bd8;
  transform: translate(-50%, -50%);
  box-sizing: border-box;
}

.forecast-night {
  margin-top: 7rpx;
}

.forecast-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.forecast-row {
  min-height: 82rpx;
  display: flex;
  align-items: center;
}

.forecast-row-day {
  width: 190rpx;
  min-width: 0;
  display: flex;
  flex-direction: column;
  font-size: 25rpx;
  font-weight: 650;
}

.forecast-row-cond {
  margin-top: 4rpx;
  color: var(--muted);
  font-size: 19rpx;
  font-weight: 400;
  line-height: 1.3;
  white-space: normal;
  word-break: break-all;
}

.forecast-row-icon {
  width: 54rpx;
  text-align: center;
  font-size: 34rpx;
}

.forecast-row-range {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-left: 10rpx;
  font-size: 24rpx;
}

.range-line {
  flex: 1;
  height: 8rpx;
  position: relative;
  border-radius: 999rpx;
  overflow: hidden;
  background: rgba(16,60,116,.22);
}

.range-line-fill {
  position: absolute;
  top: 0;
  height: 100%;
  min-width: 14rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,.76);
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.metric-item {
  min-height: 184rpx;
  padding: 18rpx 14rpx;
  border-radius: 22rpx;
  background: rgba(255,255,255,.08);
  box-sizing: border-box;
}

.metric-icon {
  font-size: 30rpx;
}

.metric-label {
  margin-top: 10rpx;
  font-size: 20rpx;
  color: var(--muted);
}

.metric-value {
  margin-top: 8rpx;
  font-size: 27rpx;
  line-height: 1.28;
  font-weight: 720;
  overflow-wrap: anywhere;
}

.metric-note {
  margin-top: 7rpx;
  font-size: 17rpx;
  line-height: 1.3;
  color: rgba(255,255,255,.46);
}

.sun-labels {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.sun-right {
  text-align: right;
}

.sun-name {
  font-size: 21rpx;
  color: var(--muted);
}

.sun-time {
  margin-top: 6rpx;
  font-size: 37rpx;
  font-weight: 650;
}

.sun-icon {
  font-size: 44rpx;
}

.sun-track {
  height: 8rpx;
  margin: 22rpx 6rpx 4rpx;
  position: relative;
  border-radius: 999rpx;
  background: rgba(18,63,123,.22);
}

.sun-track-passed {
  height: 100%;
  border-radius: 999rpx;
  background: rgba(255,255,255,.76);
}

.sun-track-dot {
  position: absolute;
  top: 50%;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #fff;
  transform: translate(-50%, -50%);
  box-shadow: 0 0 20rpx rgba(255,255,255,.56);
}

.lifestyle-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx 10rpx;
}

.lifestyle-item {
  min-height: 138rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.lifestyle-icon {
  font-size: 40rpx;
}

.lifestyle-value {
  width: 100%;
  margin-top: 10rpx;
  min-height: 52rpx;
  white-space: normal;
  word-break: break-all;
  line-height: 1.25;
  font-size: 22rpx;
  font-weight: 650;
}

.lifestyle-label {
  margin-top: 5rpx;
  font-size: 18rpx;
  color: var(--muted);
}

.data-note {
  margin: 4rpx 4rpx 0;
  padding: 20rpx 22rpx;
  border-radius: 22rpx;
  background: rgba(28,75,132,.24);
}

.data-note-title {
  margin-bottom: 10rpx;
  font-size: 22rpx;
  font-weight: 650;
}

.data-note-row {
  display: flex;
  align-items: flex-start;
  margin-top: 7rpx;
  color: rgba(255,255,255,.58);
  font-size: 19rpx;
  line-height: 1.45;
}

.data-note-dot {
  flex-shrink: 0;
  width: 8rpx;
  height: 8rpx;
  margin: 10rpx 12rpx 0 0;
  border-radius: 50%;
  background: #80d5a5;
}

.data-note-dot.estimate {
  background: #ffd179;
}

.footer-safe-area {
  height: calc(60rpx + env(safe-area-inset-bottom));
}

.preview-city {
  font-size: 40rpx;
  font-weight: 700;
}

.preview-temp {
  margin-top: 22rpx;
  font-size: 120rpx;
  font-weight: 250;
}

.preview-meta {
  margin-top: 16rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,.13);
  font-size: 23rpx;
}

.city-panel-mask {
  position: fixed;
  inset: 0;
  z-index: 200;
  background: rgba(8,26,50,.52);
}

.city-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 201;
  max-height: 76vh;
  padding: 14rpx 28rpx calc(28rpx + env(safe-area-inset-bottom));
  border-radius: 34rpx 34rpx 0 0;
  box-sizing: border-box;
  background: #f4f7fb;
  color: #14213d;
  animation: panel-in .22s ease-out;
}

@keyframes panel-in {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.panel-grabber {
  width: 70rpx;
  height: 8rpx;
  margin: 0 auto 22rpx;
  border-radius: 999rpx;
  background: #d7dfeb;
}

.panel-head,
.panel-city,
.panel-city-name-row,
.panel-weather,
.panel-actions {
  display: flex;
  align-items: center;
}

.panel-head,
.panel-city {
  justify-content: space-between;
}

.panel-head {
  margin-bottom: 20rpx;
}

.panel-title {
  font-size: 36rpx;
  font-weight: 760;
}

.panel-sub {
  margin-top: 5rpx;
  color: #8290a3;
  font-size: 22rpx;
}

.panel-add {
  width: 68rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #286de3;
  color: #fff;
  font-size: 40rpx;
}

.panel-city-list {
  max-height: 47vh;
}

.panel-city {
  min-height: 124rpx;
  margin-bottom: 14rpx;
  padding: 20rpx 22rpx;
  border: 2rpx solid transparent;
  border-radius: 22rpx;
  box-sizing: border-box;
  background: #fff;
}

.panel-city.active {
  border-color: rgba(40,109,227,.38);
  background: #edf4ff;
}

.panel-city-main {
  flex: 1;
  min-width: 0;
}

.panel-city-name {
  max-width: 300rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 31rpx;
  font-weight: 700;
}

.panel-location-badge,
.panel-current-badge {
  margin-left: 10rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
}

.panel-location-badge {
  color: #2674d8;
  background: #e8f3ff;
}

.panel-current-badge {
  color: #168253;
  background: #e4f7ed;
}

.panel-city-meta {
  margin-top: 8rpx;
  color: #8290a3;
  font-size: 22rpx;
}

.panel-weather {
  gap: 10rpx;
}

.panel-temp {
  font-size: 40rpx;
  font-weight: 350;
}

.panel-check {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #286de3;
  color: #fff;
  font-size: 20rpx;
}

.panel-actions {
  gap: 16rpx;
  margin-top: 8rpx;
}

.panel-action {
  flex: 1;
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  font-size: 27rpx;
  font-weight: 680;
}

.panel-action.ghost {
  background: #e8edf5;
  color: #40506a;
}

.panel-action.primary {
  background: #286de3;
  color: #fff;
}
