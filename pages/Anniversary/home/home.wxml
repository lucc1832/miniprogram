<view class="container">
  <view class="hero">
    <view class="hero-row">
      <view>
        <view class="hero-kicker">纪念日</view>
        <view class="hero-title">时间纪念馆</view>
      </view>
      <view class="hero-add" bindtap="goCreate">添加</view>
    </view>

    <view class="emotion-quote">
      <text>{{dailyEmotion}}</text>
    </view>

    <view class="stats-row">
      <view class="stat-item">
        <view class="stat-num">{{stats.totalCount}}</view>
        <view class="stat-label">全部</view>
      </view>
      <view class="stat-item">
        <view class="stat-num">{{stats.countdownCount}}</view>
        <view class="stat-label">倒数</view>
      </view>
      <view class="stat-item">
        <view class="stat-num">{{stats.todayCount}}</view>
        <view class="stat-label">今天</view>
      </view>
      <view class="stat-item">
        <view class="stat-num">{{stats.importantCount}}</view>
        <view class="stat-label">重要</view>
      </view>
    </view>
  </view>

  <view class="main-card-wrapper" wx:if="{{mainEvent}}" bindtap="goDetail" data-id="{{mainEvent.id}}">
    <view class="main-card {{mainEvent.tone}}">
      <view class="card-header">
        <view class="card-label">{{mainEvent.typeText}} · {{mainEvent.tagText}} · {{mainEvent.shortDate}}</view>
        <view class="important-chip" wx:if="{{mainEvent.isImportant}}">重要</view>
      </view>
      <view class="card-title">{{mainEvent.title}}</view>
      <view class="card-body">
        <view class="big-days">{{mainEvent.days}}</view>
        <view class="unit-wrap">
          <view class="card-label">{{mainEvent.label}}</view>
          <view class="unit">天</view>
        </view>
      </view>
      <view class="card-footer">{{mainEvent.emotion}}</view>
      <view class="card-date">{{mainEvent.calendarText}} · {{mainEvent.date}}</view>
      <view class="bg-decoration"></view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{!mainEvent && !loading}}">
    <view class="empty-title">还没有纪念日</view>
    <view class="empty-text">把生日、第一次见面、旅行和重要节点都收进来，首页会自动排出最值得关注的日子。</view>
    <view class="empty-btn" bindtap="goCreate">添加第一个</view>
  </view>

  <view class="section" wx:if="{{todayEvents.length > 0}}">
    <view class="section-head">
      <view>
        <view class="section-title">今天发生</view>
        <view class="section-sub">当天提醒会优先显示在这里</view>
      </view>
      <view class="section-count">{{todayEvents.length}}</view>
    </view>
    <block wx:for="{{todayEvents}}" wx:key="id">
      <view class="timeline-card {{item.tone}}" bindtap="goDetail" data-id="{{item.id}}">
        <view class="timeline-dot {{item.tone}}"></view>
        <view class="timeline-main">
          <view class="timeline-title">{{item.title}}</view>
          <view class="timeline-meta">{{item.typeText}} · {{item.tagText}} · {{item.date}}</view>
        </view>
        <view class="timeline-days">
          <text>{{item.label}}</text>
          <view>{{item.days}}天</view>
        </view>
      </view>
    </block>
  </view>

  <view class="section" wx:if="{{upcomingEvents.length > 0}}">
    <view class="section-head">
      <view>
        <view class="section-title">即将到来</view>
        <view class="section-sub">倒数日按最近时间排序</view>
      </view>
      <view class="section-count">{{upcomingEvents.length}}</view>
    </view>
    <block wx:for="{{upcomingEvents}}" wx:key="id">
      <view class="timeline-card {{item.tone}}" bindtap="goDetail" data-id="{{item.id}}">
        <view class="timeline-dot {{item.tone}}"></view>
        <view class="timeline-main">
          <view class="timeline-title">{{item.title}}</view>
          <view class="timeline-meta">{{item.typeText}} · {{item.tagText}} · {{item.shortDate}}</view>
        </view>
        <view class="timeline-days">
          <text>{{item.label}}</text>
          <view>{{item.days}}天</view>
        </view>
      </view>
    </block>
  </view>

  <view class="section" wx:if="{{memoryEvents.length > 0}}">
    <view class="section-head">
      <view>
        <view class="section-title">珍贵回忆</view>
        <view class="section-sub">已经走过的时间会沉淀在这里</view>
      </view>
      <view class="section-count">{{memoryEvents.length}}</view>
    </view>
    <block wx:for="{{memoryEvents}}" wx:key="id">
      <view class="timeline-card {{item.tone}}" bindtap="goDetail" data-id="{{item.id}}">
        <view class="timeline-dot {{item.tone}}"></view>
        <view class="timeline-main">
          <view class="timeline-title">{{item.title}}</view>
          <view class="timeline-meta">{{item.typeText}} · {{item.tagText}} · {{item.shortDate}}</view>
        </view>
        <view class="timeline-days">
          <text>{{item.label}}</text>
          <view>{{item.days}}天</view>
        </view>
      </view>
    </block>
  </view>

  <view class="fab" bindtap="goCreate">
    <view class="plus">+</view>
  </view>
</view>
