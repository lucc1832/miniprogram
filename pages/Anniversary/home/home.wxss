.container {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 32rpx 28rpx calc(164rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #f7f8fb 0%, #eef5ff 48%, #fff7f3 100%);
  color: #172033;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.hero {
  padding: 30rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #172033 0%, #293b63 58%, #d86f45 100%);
  color: #ffffff;
  box-shadow: 0 20rpx 44rpx rgba(23, 32, 51, .18);
  overflow: hidden;
}

.hero-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24rpx;
}

.hero-kicker {
  font-size: 24rpx;
  opacity: .74;
}

.hero-title {
  margin-top: 8rpx;
  font-size: 44rpx;
  line-height: 1.15;
  font-weight: 800;
}

.hero-add {
  min-width: 112rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .16);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
}

.emotion-quote {
  margin-top: 30rpx;
  padding: 22rpx 0 4rpx;
  color: rgba(255, 255, 255, .82);
  font-size: 26rpx;
  line-height: 1.55;
}

.stats-row {
  margin-top: 28rpx;
  display: flex;
  gap: 12rpx;
}

.stat-item {
  flex: 1;
  min-width: 0;
  padding: 18rpx 10rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .12);
  text-align: center;
}

.stat-item.active {
  color: #172033;
  background: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, .12);
}

.stat-item.active .stat-label {
  opacity: .66;
}

.empty-illustration {
  width: 100rpx;
  height: 100rpx;
  line-height: 96rpx;
  margin: 0 auto 22rpx;
  border-radius: 50%;
  color: #d86f45;
  background: #fff0ea;
  font-size: 54rpx;
  text-align: center;
}

.stat-num {
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1;
}

.stat-label {
  margin-top: 10rpx;
  font-size: 22rpx;
  opacity: .72;
}

.main-card-wrapper {
  margin-top: 26rpx;
}

.main-card {
  position: relative;
  overflow: hidden;
  min-height: 420rpx;
  box-sizing: border-box;
  padding: 32rpx;
  border-radius: 16rpx;
  color: #ffffff;
  box-shadow: 0 18rpx 42rpx rgba(33, 48, 84, .16);
}

.main-card.countdown {
  background: linear-gradient(135deg, #3152a9 0%, #4b87e8 58%, #5fc8b1 100%);
}

.main-card.memory {
  background: linear-gradient(135deg, #343c4f 0%, #6d7484 56%, #d8a15f 100%);
}

.main-card.important {
  background: linear-gradient(135deg, #7c3aed 0%, #db5f83 60%, #f3a65a 100%);
}

.main-card.today {
  background: linear-gradient(135deg, #c2415d 0%, #f06f55 58%, #f6bd60 100%);
}

.card-header {
  position: relative;
  z-index: 2;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
}

.card-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, .72);
}

.important-chip {
  padding: 8rpx 14rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, .18);
  font-size: 22rpx;
  font-weight: 700;
}

.card-title {
  position: relative;
  z-index: 2;
  margin-top: 28rpx;
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 800;
}

.card-body {
  position: relative;
  z-index: 2;
  margin-top: 30rpx;
  display: flex;
  align-items: flex-end;
  gap: 18rpx;
}

.big-days {
  font-size: 140rpx;
  line-height: .88;
  font-weight: 900;
}

.unit-wrap {
  padding-bottom: 10rpx;
}

.unit {
  margin-top: 4rpx;
  font-size: 34rpx;
  font-weight: 800;
}

.card-footer {
  position: relative;
  z-index: 2;
  margin-top: 34rpx;
  max-width: 560rpx;
  color: rgba(255, 255, 255, .84);
  font-size: 26rpx;
  line-height: 1.5;
}

.card-date {
  position: relative;
  z-index: 2;
  margin-top: 18rpx;
  color: rgba(255, 255, 255, .64);
  font-size: 22rpx;
}

.bg-decoration {
  position: absolute;
  right: -60rpx;
  bottom: -70rpx;
  width: 260rpx;
  height: 160rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .10);
  transform: rotate(-18deg);
}

.empty-state {
  margin-top: 26rpx;
  padding: 70rpx 38rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .86);
  text-align: center;
  box-shadow: 0 12rpx 30rpx rgba(61, 73, 105, .07);
}

.empty-title {
  color: #172033;
  font-size: 34rpx;
  font-weight: 800;
}

.empty-text {
  margin-top: 16rpx;
  color: #7b8497;
  font-size: 26rpx;
  line-height: 1.55;
}

.empty-btn {
  margin: 30rpx auto 0;
  width: 190rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: #172033;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 800;
}

.section {
  margin-top: 28rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 20rpx;
  margin-bottom: 16rpx;
  padding: 0 4rpx;
}

.section-title {
  color: #172033;
  font-size: 32rpx;
  font-weight: 800;
}

.section-sub {
  margin-top: 6rpx;
  color: #8a93a5;
  font-size: 22rpx;
}

.section-count {
  width: 52rpx;
  height: 52rpx;
  border-radius: 16rpx;
  background: #ffffff;
  color: #526079;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
}

.timeline-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 14rpx;
  padding: 22rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .9);
  border: 1rpx solid rgba(228, 233, 242, .9);
  box-shadow: 0 10rpx 24rpx rgba(58, 69, 98, .06);
}

.timeline-dot {
  width: 18rpx;
  height: 56rpx;
  border-radius: 10rpx;
  background: #8b95aa;
  flex-shrink: 0;
}

.timeline-dot.countdown {
  background: #4b87e8;
}

.timeline-dot.memory {
  background: #d8a15f;
}

.timeline-dot.important {
  background: #db5f83;
}

.timeline-dot.today {
  background: #f06f55;
}

.timeline-main {
  flex: 1;
  min-width: 0;
}

.timeline-title {
  color: #172033;
  font-size: 30rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.timeline-meta {
  margin-top: 8rpx;
  color: #8a93a5;
  font-size: 22rpx;
}

.timeline-days {
  min-width: 112rpx;
  text-align: right;
  color: #172033;
  font-size: 30rpx;
  font-weight: 800;
}

.timeline-days text {
  display: block;
  margin-bottom: 4rpx;
  color: #8a93a5;
  font-size: 20rpx;
  font-weight: 600;
}

.fab {
  position: fixed;
  right: 38rpx;
  bottom: calc(70rpx + env(safe-area-inset-bottom));
  width: 102rpx;
  height: 102rpx;
  border-radius: 51rpx;
  background: #172033;
  box-shadow: 0 18rpx 38rpx rgba(23, 32, 51, .22);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.plus {
  margin-top: -6rpx;
  color: #ffffff;
  font-size: 58rpx;
  font-weight: 300;
}
